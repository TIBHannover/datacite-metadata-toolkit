<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
>
  <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
  </owl:Class>
  <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme">
  </owl:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/AlternateIdentifier">
    <rdfs:comment>An identifier other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string which is unique within its domain of issue. May be used for local identifiers, a serial number of an instrument or an inventory number. The AlternateIdentifier should be an additional identifier for the same instance of the resource (i.e., same location, same file).</rdfs:comment>
    <rdfs:label>AlternateIdentifier</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Contributor">
    <rdfs:comment> The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property. For software, if there is an alternate entity that “holds, archives, publishes, prints, distributes, releases, issues, or produces” the code, use the contributorType “HostingInstitution” for the code repository. For instruments, if there is an institution responsible for the management of the instrument (for example, the legal owner, the operator, or an institute providing access to the instrument), use the contributorType “HostingInstitution” for the owner of the instrument.</rdfs:comment>
    <rdfs:label>Contributor</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Creator">
    <rdfs:comment>The main researchers involved in producing the data, or the authors of the publication, in priority order. For instruments this is the manufacturer or developer of the instrument. To supply multiple creators, repeat this property.</rdfs:comment>
    <rdfs:label>Creator</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Date">
    <rdfs:comment>Different dates relevant to the work.</rdfs:comment>
    <rdfs:label>Date</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Description">
    <rdfs:comment> All additional information that does not fit in any of the other categories. May be used for technical information or detailed information associated with a scientific instrument.</rdfs:comment>
    <rdfs:label>Description</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Format">
    <rdfs:comment>Technical format of the resource.</rdfs:comment>
    <rdfs:label>Format</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/FundingReference">
    <rdfs:comment>Information about financial support (funding) for the resource being registered.</rdfs:comment>
    <rdfs:label>FundingReference</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/GeoLocation">
    <rdfs:comment>Spatial region or named place where the data was gathered or about which the data is focused.</rdfs:comment>
    <rdfs:label>GeoLocation</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Identifier">
    <rdfs:comment>The Identifier is a unique string that identifies a resource.</rdfs:comment>
    <rdfs:label>Identifier</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Language">
    <rdfs:comment>The primary language of the resource.</rdfs:comment>
    <rdfs:label>Language</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/PublicationYear">
    <rdfs:comment>The year when the data was or will be made publicly available. In the case of resources such as software or dynamic data where there may be multiple releases in one year, include the Date property and sub-properties (dateType/dateInformation) to provide more information about the publication or release date details.</rdfs:comment>
    <rdfs:label>PublicationYear</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Publisher">
    <rdfs:comment>The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.</rdfs:comment>
    <rdfs:label>Publisher</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/RelatedIdentifier">
    <rdfs:comment>Identifiers of related resources. These must be globally unique identifiers.</rdfs:comment>
    <rdfs:label>RelatedIdentifier</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/RelatedItem">
    <rdfs:comment>Information about a resource related to the one being registered.</rdfs:comment>
    <rdfs:label>RelatedItem</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Resource">
    <rdfs:comment>Any object (data, software, instrument, document, sample, etc.) that can be cited via a DataCite-assigned persistent identifier (DOI). This is the root class of the DataCite Metadata Schema; every DataCite record describes exactly one Resource.</rdfs:comment>
    <rdfs:label>Resource</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/ResourceType">
    <rdfs:comment>A description of the resource.</rdfs:comment>
    <rdfs:label>ResourceType</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Rights">
    <rdfs:comment>Any rights information for this resource.</rdfs:comment>
    <rdfs:label>Rights</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Size">
    <rdfs:comment>Size (e.g., bytes, pages, inches, etc.) or duration (extent), e.g., hours, minutes, days, etc., of a resource.</rdfs:comment>
    <rdfs:label>Size</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Subject">
    <rdfs:comment>Subject, keyword, classification code, or key phrase describing the resource.</rdfs:comment>
    <rdfs:label>Subject</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Title">
    <rdfs:comment>A name or title by which a resource is known. May be the title of a dataset or the name of a piece of software or an instrument.</rdfs:comment>
    <rdfs:label>Title</rdfs:label>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://w3id.org/tib/datacite/class/Version">
    <rdfs:comment>The version number of the resource.</rdfs:comment>
    <rdfs:label>Version</rdfs:label>
  </rdfs:Class>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/affiliation">
    <rdfs:comment>The organizational or institutional affiliation of the creator.</rdfs:comment>
    <rdfs:label>affiliation</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/affiliationIdentifier">
    <rdfs:comment>Uniquely identifies the organizational affiliation of the creator.</rdfs:comment>
    <rdfs:label>affiliationIdentifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/affiliationIdentifierScheme">
    <rdfs:comment>The name of the affiliation identifier scheme</rdfs:comment>
    <rdfs:label>affiliationIdentifierScheme</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/alternateIdentifier">
    <rdfs:comment>An identifier or identifiers other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string unique within its domain of issue, such as a local identifier, a serial number of an instrument, or an inventory number.</rdfs:comment>
    <rdfs:label>alternateIdentifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/alternateIdentifierType">
    <rdfs:comment>The type of the AlternateIdentifier.</rdfs:comment>
    <rdfs:label>alternateIdentifierType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/awardNumber">
    <rdfs:comment>The code assigned by the funder to a sponsored award (grant).</rdfs:comment>
    <rdfs:label>awardNumber</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/awardTitle">
    <rdfs:comment>The human readable title or name of the award (grant).</rdfs:comment>
    <rdfs:label>awardTitle</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/awardURI">
    <rdfs:comment>The URI leading to a page provided by the funder for more information about the award (grant).</rdfs:comment>
    <rdfs:label>awardURI</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/classificationCode">
    <rdfs:comment>The classification code used for the subject term in the subject scheme.</rdfs:comment>
    <rdfs:label>classificationCode</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/contributor">
    <rdfs:comment>The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property.</rdfs:comment>
    <rdfs:label>contributor</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/contributorName">
    <rdfs:comment>The full name of the contributor.</rdfs:comment>
    <rdfs:label>contributorName</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/contributorType">
    <rdfs:comment>The type of contributor of the resource.</rdfs:comment>
    <rdfs:label>contributorType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/creator">
    <rdfs:comment>The main researchers involved in producing the data, or the authors of the publication, in priority order. For instruments this is the manufacturer or developer of the instrument. To supply multiple creators, repeat this property.</rdfs:comment>
    <rdfs:label>creator</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/creatorName">
    <rdfs:comment>The full name of the creator.</rdfs:comment>
    <rdfs:label>creatorName</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/date">
    <rdfs:comment>Different dates relevant to the work.</rdfs:comment>
    <rdfs:label>date</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/dateInformation">
    <rdfs:comment>Specific information about the date, if appropriate.</rdfs:comment>
    <rdfs:label>dateInformation</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/dateType">
    <rdfs:comment>The type of date.</rdfs:comment>
    <rdfs:label>dateType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/description">
    <rdfs:comment>All additional information that does not fit in any of the other categories. May be used for technical information or detailed information associated with a scientific instrument.</rdfs:comment>
    <rdfs:label>description</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/descriptionType">
    <rdfs:comment>The type of the Description.</rdfs:comment>
    <rdfs:label>descriptionType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/eastBoundLongitude">
    <rdfs:comment>Eastern longitudinal dimension of box.</rdfs:comment>
    <rdfs:label>eastBoundLongitude</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/edition">
    <rdfs:comment>Edition or version of the related item.</rdfs:comment>
    <rdfs:label>edition</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/familyName">
    <rdfs:comment>The surname or last name of the creator.</rdfs:comment>
    <rdfs:label>familyName</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/firstPage">
    <rdfs:comment>First page of the resource within the related item, e.g., of the chapter, article, or conference paper in proceedings.</rdfs:comment>
    <rdfs:label>firstPage</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/format">
    <rdfs:comment>Technical format of the resource.</rdfs:comment>
    <rdfs:label>format</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/funderIdentifier">
    <rdfs:comment>Uniquely identifies a funding entity, according to various types.</rdfs:comment>
    <rdfs:label>funderIdentifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/funderIdentifierType">
    <rdfs:comment>The type of the funderIdentifier.</rdfs:comment>
    <rdfs:label>funderIdentifierType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/funderName">
    <rdfs:comment>Name of the funding provider.</rdfs:comment>
    <rdfs:label>funderName</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/fundingReference">
    <rdfs:comment>Information about financial support (funding) for the resource being registered.</rdfs:comment>
    <rdfs:label>fundingReference</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/geoLocation">
    <rdfs:comment>Spatial region or named place where the data was gathered or about which the data is focused.</rdfs:comment>
    <rdfs:label>geoLocation</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/geoLocationBox">
    <rdfs:comment>The spatial limits of a box.</rdfs:comment>
    <rdfs:label>geoLocationBox</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/geoLocationPlace">
    <rdfs:comment>Description of a geographic location.</rdfs:comment>
    <rdfs:label>geoLocationPlace</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/geoLocationPoint">
    <rdfs:comment>A point location in space.</rdfs:comment>
    <rdfs:label>geoLocationPoint</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/geoLocationPolygon">
    <rdfs:comment>A drawn polygon area, defined by a set of points and lines connecting the points in a closed chain.</rdfs:comment>
    <rdfs:label>geoLocationPolygon</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/givenName">
    <rdfs:comment>The personal or first name of the creator.</rdfs:comment>
    <rdfs:label>givenName</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/identifier">
    <rdfs:comment>The Identifier is a unique string that identifies a resource.</rdfs:comment>
    <rdfs:label>identifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/identifierType">
    <rdfs:comment>The type of Identifier.</rdfs:comment>
    <rdfs:label>identifierType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/inPolygonPoint">
    <rdfs:comment>A point location in a polygon.</rdfs:comment>
    <rdfs:label>inPolygonPoint</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/issue">
    <rdfs:comment>Issue number or name of the related item.</rdfs:comment>
    <rdfs:label>issue</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/language">
    <rdfs:comment>The primary language of the resource.</rdfs:comment>
    <rdfs:label>language</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/lastPage">
    <rdfs:comment>Last page of the resource within the related item, e.g., of the chapter, article, or conference paper in proceedings.</rdfs:comment>
    <rdfs:label>lastPage</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/nameIdentifier">
    <rdfs:comment>Uniquely identifies an individual or legal entity, according to various schemes.</rdfs:comment>
    <rdfs:label>nameIdentifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/nameIdentifierScheme">
    <rdfs:comment>The name of the name identifier scheme.</rdfs:comment>
    <rdfs:label>nameIdentifierScheme</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/nameType">
    <rdfs:comment>The type of name.</rdfs:comment>
    <rdfs:label>nameType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/northBoundLatitude">
    <rdfs:comment>Northern latitudinal dimension of box.</rdfs:comment>
    <rdfs:label>northBoundLatitude</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/number">
    <rdfs:comment>Number of the resource within the related item, e.g., report number or article number.</rdfs:comment>
    <rdfs:label>number</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/numberType">
    <rdfs:comment>Type of the related item’s number, e.g., report number or article number.</rdfs:comment>
    <rdfs:label>numberType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/pointLatitude">
    <rdfs:comment>Latitudinal dimension of point.</rdfs:comment>
    <rdfs:label>pointLatitude</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/pointLongitude">
    <rdfs:comment>Longitudinal dimension of point.</rdfs:comment>
    <rdfs:label>pointLongitude</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/polygonPoint">
    <rdfs:comment>A point location in a polygon.</rdfs:comment>
    <rdfs:label>polygonPoint</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/publicationYear">
    <rdfs:comment>The year when the item was or will be made publicly available.</rdfs:comment>
    <rdfs:label>publicationYear</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/publisher">
    <rdfs:comment>The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.</rdfs:comment>
    <rdfs:label>publisher</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/publisherIdentifier">
    <rdfs:comment>Uniquely identifies the publisher, according to various schemes.</rdfs:comment>
    <rdfs:label>publisherIdentifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/publisherIdentifierScheme">
    <rdfs:comment>The name of the publisher identifier scheme.</rdfs:comment>
    <rdfs:label>publisherIdentifierScheme</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relatedIdentifier">
    <rdfs:comment>Identifiers of related resources. These must be globally unique identifiers.</rdfs:comment>
    <rdfs:label>relatedIdentifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relatedIdentifierType">
    <rdfs:comment>The type of the RelatedIdentifier.</rdfs:comment>
    <rdfs:label>relatedIdentifierType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relatedItem">
    <rdfs:comment>Information about a resource related to the one being registered.</rdfs:comment>
    <rdfs:label>relatedItem</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relatedItemIdentifier">
    <rdfs:comment>The identifier for the related item.</rdfs:comment>
    <rdfs:label>relatedItemIdentifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relatedItemIdentifierType">
    <rdfs:comment>The type of the Identifier for the related item.</rdfs:comment>
    <rdfs:label>relatedItemIdentifierType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relatedItemType">
    <rdfs:comment>The general type of the related item.</rdfs:comment>
    <rdfs:label>relatedItemType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relatedMetadataScheme">
    <rdfs:comment>The name of the scheme.</rdfs:comment>
    <rdfs:label>relatedMetadataScheme</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relationType">
    <rdfs:comment>Description of the relationship of the resource being registered (A) and the related resource (B).</rdfs:comment>
    <rdfs:label>relationType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/relationTypeInformation">
    <rdfs:comment>Additional information about the selected relationType, if appropriate.</rdfs:comment>
    <rdfs:label>relationTypeInformation</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/resourceType">
    <rdfs:comment>A description of the resource.</rdfs:comment>
    <rdfs:label>resourceType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/resourceTypeGeneral">
    <rdfs:comment>The general type of a resource.</rdfs:comment>
    <rdfs:label>resourceTypeGeneral</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/rights">
    <rdfs:comment>Any rights information for this resource.</rdfs:comment>
    <rdfs:label>rights</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/rightsIdentifier">
    <rdfs:comment>A short standardized identifier for the licence.</rdfs:comment>
    <rdfs:label>rightsIdentifier</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/rightsIdentifierScheme">
    <rdfs:comment>The name of the scheme.</rdfs:comment>
    <rdfs:label>rightsIdentifierScheme</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/rightsURI">
    <rdfs:comment>The URI of the license.</rdfs:comment>
    <rdfs:label>rightsURI</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/schemeType">
    <rdfs:comment>The type of the relatedMetadataScheme, linked with the schemeURI.</rdfs:comment>
    <rdfs:label>schemeType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/schemeURI">
    <rdfs:comment>The URI of an identifier scheme.</rdfs:comment>
    <rdfs:label>schemeURI</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/size">
    <rdfs:comment>Size (e.g., bytes, pages, inches, etc.) or duration (extent), e.g., hours, minutes, days, etc., of a resource.</rdfs:comment>
    <rdfs:label>size</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/southBoundLatitude">
    <rdfs:comment>Southern latitude of box .</rdfs:comment>
    <rdfs:label>southBoundLatitude</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/subject">
    <rdfs:comment>Subject, keyword, classification code, or key phrase describing the resource.</rdfs:comment>
    <rdfs:label>subject</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/subjectScheme">
    <rdfs:comment>The name of the subject scheme or classification code or authority if one is used.</rdfs:comment>
    <rdfs:label>subjectScheme</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/title">
    <rdfs:comment>A name or title by which a resource is known. May be the title of a dataset or the name of a piece of software or an instrument.</rdfs:comment>
    <rdfs:label>title</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/titleType">
    <rdfs:comment>The type of Title (other than the Main Title).</rdfs:comment>
    <rdfs:label>titleType</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/valueURI">
    <rdfs:comment> The URI of the subject term.</rdfs:comment>
    <rdfs:label>valueURI</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/version">
    <rdfs:comment>The version number of the resource.</rdfs:comment>
    <rdfs:label>version</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/volume">
    <rdfs:comment>Volume of the related item.</rdfs:comment>
    <rdfs:label>volume</rdfs:label>
  </rdf:Property>
  <rdf:Property rdf:about="https://w3id.org/tib/datacite/property/westBoundLongitude">
    <rdfs:comment>Western longitudinal dimension of box.</rdfs:comment>
    <rdfs:label>westBoundLongitude</rdfs:label>
  </rdf:Property>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/contributorType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-18</dcterms:created>
    <dcterms:identifier>contributorType</dcterms:identifier>
    <dcterms:title>DataCite contributorType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/ContactPerson"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/DataCollector"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/DataCurator"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/DataManager"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/Distributor"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/Editor"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/HostingInstitution"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/Other"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/Producer"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/ProjectLeader"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/ProjectManager"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/ProjectMember"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/RegistrationAgency"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/RegistrationAuthority"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/RelatedPerson"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/ResearchGroup"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/Researcher"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/RightsHolder"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/Sponsor"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/Supervisor"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/Translator"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType/WorkPackageLeader"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/ContactPerson">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person with knowledge of how to access, troubleshoot, or otherwise field issues related to the resource.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>ContactPerson</skos:notation>
    <skos:prefLabel>ContactPerson</skos:prefLabel>
    <skos:scopeNote>May also be the “Point of Contact” in an organisation that controls access to the resource, if that organisation is different from the Publisher, Distributor, and Data Manager.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/DataCollector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person/institution responsible for finding or gathering/collecting data under the guidelines of the author(s) or Principal Investigator (PI).</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>DataCollector</skos:notation>
    <skos:prefLabel>DataCollector</skos:prefLabel>
    <skos:scopeNote>May also be used when crediting survey conductors, interviewers, event or condition observers, or persons responsible for monitoring key instrument data.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/DataCurator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person tasked with reviewing, enhancing, cleaning, or standardizing metadata and the associated data submitted for storage, use, and maintenance within a data centre or repository.</skos:definition>
    <skos:example>https://doi.org/10.20375/0000-000D-1D1F-2</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>DataCurator</skos:notation>
    <skos:prefLabel>DataCurator</skos:prefLabel>
    <skos:scopeNote>While the DataManager is concerned with digital maintenance, the DataCurator’s role encompasses quality assurance focused on content and metadata. Responsibilities can include checking completeness; verifying standard metadata; adding/verifying specialized metadata; and determining how metadata maps to search engines, database products, and automated feeds. Repository managers and data librarians may fall within this category.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/DataManager">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person (or organisation with a staff of data managers, such as a data centre) responsible for maintaining the finished resource.</skos:definition>
    <skos:example>https://doi.org/10.6073/pasta/41b3ed2e152e1e4c3846e646118208e7</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>DataManager</skos:notation>
    <skos:prefLabel>DataManager</skos:prefLabel>
    <skos:scopeNote>Ensures the resource is periodically refreshed (software/hardware support), kept available/protected from unauthorized access, stored according to industry standards, and handled according to applicable records management requirements.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/Distributor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Institution tasked with responsibility to generate/disseminate copies of the resource in either electronic or print form.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>Distributor</skos:notation>
    <skos:prefLabel>Distributor</skos:prefLabel>
    <skos:scopeNote>Works stored in more than one archive/repository may credit each as a distributor.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/Editor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A person who oversees the details related to the publication format of the resource.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>Editor</skos:notation>
    <skos:prefLabel>Editor</skos:prefLabel>
    <skos:scopeNote>If the Editor is to be credited in place of multiple creators, the Editor’s name may be supplied as Creator, with “(Ed.)” appended to the name.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/HostingInstitution">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Typically, the organisation allowing the resource to be available on the internet through the provision of its hardware/software/operating support.</skos:definition>
    <skos:example>Université Grenoble Alpes (UGA)</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>HostingInstitution</skos:notation>
    <skos:prefLabel>HostingInstitution</skos:prefLabel>
    <skos:scopeNote>This role normally falls on the university, research center, or organization where the data center/repository belongs. May also be used for an organisation that stores the data offline, often a data centre if that data centre is not the publisher.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Any person or institution making a significant contribution to the development and/or maintenance of the resource, but whose contribution is not adequately described by any of the other values for contributorType.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>Other</skos:notation>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:scopeNote>Could be a photographer, artist, or writer whose contribution helped to publicize the resource (as opposed to creating it), a reviewer, someone providing administrative services (depositing updates, analysing usage), etc.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/Producer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Typically, a person or organisation responsible for the artistry and form of a media product.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>Producer</skos:notation>
    <skos:prefLabel>Producer</skos:prefLabel>
    <skos:scopeNote>In the data industry, this may be a company producing DVDs that package data for future dissemination by a distributor.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/ProjectLeader">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person officially designated as head of project team or sub-project team instrumental in the work necessary to development of the resource.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>ProjectLeader</skos:notation>
    <skos:prefLabel>ProjectLeader</skos:prefLabel>
    <skos:scopeNote>The Project Leader remains intimately involved throughout the life of the particular project team.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/ProjectManager">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person officially designated as manager of a project. Project may consist of one or many project teams and sub-teams.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>ProjectManager</skos:notation>
    <skos:prefLabel>ProjectManager</skos:prefLabel>
    <skos:scopeNote>The manager of a project normally has more administrative responsibility than actual work involvement.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/ProjectMember">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person on the membership list of a designated project/project team.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>ProjectMember</skos:notation>
    <skos:prefLabel>ProjectMember</skos:prefLabel>
    <skos:scopeNote>This vocabulary may or may not indicate the quality, quantity, or substance of the person’s involvement.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/RegistrationAgency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Institution/organisation officially appointed by a Registration Authority to handle specific tasks within a defined area of responsibility.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>RegistrationAgency</skos:notation>
    <skos:prefLabel>RegistrationAgency</skos:prefLabel>
    <skos:scopeNote>DataCite is a Registration Agency for the International DOI Foundation (IDF). One task is to assign DOI prefixes to allocating agents who then assign full DOI strings to clients and provide metadata back to the DataCite registry.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/RegistrationAuthority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A standards-setting body from which Registration Agencies obtain official recognition and guidance.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>RegistrationAuthority</skos:notation>
    <skos:prefLabel>RegistrationAuthority</skos:prefLabel>
    <skos:scopeNote>The IDF serves as the Registration Authority for the International Standards Organisation (ISO) in the area/domain of Digital Object Identifiers.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/RelatedPerson">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A person without a specifically defined role in the development of the resource, but who is someone the author wishes to recognize.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>RelatedPerson</skos:notation>
    <skos:prefLabel>RelatedPerson</skos:prefLabel>
    <skos:scopeNote>Could be an author’s intellectual mentor, a person providing intellectual leadership in the discipline or subject domain, etc.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/ResearchGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Typically refers to a group of individuals with a lab, department, or division that has a specifically defined focus of activity.</skos:definition>
    <skos:example>Space Research &amp; Planetary Sciences Division of the University of Bern (WP Unibe)</skos:example>
    <skos:example>doi:10.26302/SSHADE/EXPERIMEN T_OP_20201104_001</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>ResearchGroup</skos:notation>
    <skos:prefLabel>ResearchGroup</skos:prefLabel>
    <skos:scopeNote>May operate at a narrower level of scope; may or may not hold less administrative responsibility than a project team.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/Researcher">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A person involved in analysing data or the results of an experiment or formal study.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>Researcher</skos:notation>
    <skos:prefLabel>Researcher</skos:prefLabel>
    <skos:scopeNote>Should be a person, not an institution. A person gathering data would typically be DataCollector. A researcher may find additional data online and correlate it to collected data.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/RightsHolder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person or institution owning or managing property rights, including intellectual property rights over the resource.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>RightsHolder</skos:notation>
    <skos:prefLabel>RightsHolder</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/Sponsor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Person or organisation that issued a contract or under the auspices of which a work has been written, printed, published, developed, etc.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>Sponsor</skos:notation>
    <skos:prefLabel>Sponsor</skos:prefLabel>
    <skos:scopeNote>Includes organisations that provide in-kind support (donation, people, facility, instrumentation) necessary for development of the resource.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/Supervisor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Designated administrator over one or more groups/teams working to produce a resource, or over one or more steps of a development process.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>Supervisor</skos:notation>
    <skos:prefLabel>Supervisor</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/Translator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A person, organization, or automated system responsible for converting the content of a resource from one language into another, preserving its meaning and intended message.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>Translator</skos:notation>
    <skos:prefLabel>Translator</skos:prefLabel>
    <skos:scopeNote>Apply to DOI metadata for a resource which has been translated from another resource.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/contributorType/WorkPackageLeader">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A Work Package is a recognized data product, not all of which is included in publication. The package may include notes, discarded documents, etc. The Work Package Leader is responsible for ensuring comprehensive contents, versioning, and availability of the Work Package during development of the resource.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
    <skos:notation>WorkPackageLeader</skos:notation>
    <skos:prefLabel>WorkPackageLeader</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/contributorType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/dateType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
    <dcterms:identifier>dateType</dcterms:identifier>
    <dcterms:title>DataCite dateType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Accepted"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Available"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Collected"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Copyrighted"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Coverage"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Created"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Issued"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Other"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Submitted"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Updated"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Valid"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/dateType/Withdrawn"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Accepted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date that the publisher accepted the resource into their system.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Accepted</skos:notation>
    <skos:prefLabel>Accepted</skos:prefLabel>
    <skos:scopeNote>To indicate the start of an embargo period, use Accepted or Submitted, as appropriate.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Available">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date the resource is made publicly available. May be a range.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Available</skos:notation>
    <skos:prefLabel>Available</skos:prefLabel>
    <skos:scopeNote>To indicate the end of an embargo period, use Available.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Collected">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date or date range in which the resource content was collected.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Collected</skos:notation>
    <skos:prefLabel>Collected</skos:prefLabel>
    <skos:scopeNote>To indicate precise or particular timeframes in which research was conducted.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Copyrighted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The specific, documented date at which the resource receives a copyrighted status, if applicable.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Copyrighted</skos:notation>
    <skos:prefLabel>Copyrighted</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Coverage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date or date range that the resource content applies to, describes, or covers.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Coverage</skos:notation>
    <skos:prefLabel>Coverage</skos:prefLabel>
    <skos:scopeNote>To indicate the temporal coverage of the resource, use Coverage. This may be different from Collected.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Created">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date the resource itself was put together; this could refer to a timeframe in ancient history, a date range, or a single date for a final component, e.g., the finalised file with all the data.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Created</skos:notation>
    <skos:prefLabel>Created</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Issued">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date that the resource is published or distributed, e.g., to a data centre.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Issued</skos:notation>
    <skos:prefLabel>Issued</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Other date that does not fit into an existing category.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Other</skos:notation>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Submitted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date the creator submits the resource to the publisher. This could be different from Accepted if the publisher then applies a selection process.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Submitted</skos:notation>
    <skos:prefLabel>Submitted</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery. To indicate the start of an embargo period, use Submitted or Accepted, as appropriate.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Updated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date of the last update to the resource, when the resource is being added to. May be a range.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Updated</skos:notation>
    <skos:prefLabel>Updated</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Valid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date or date range during which the dataset or resource is accurate.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Valid</skos:notation>
    <skos:prefLabel>Valid</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/dateType/Withdrawn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The date the resource is removed.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
    <skos:notation>Withdrawn</skos:notation>
    <skos:prefLabel>Withdrawn</skos:prefLabel>
    <skos:scopeNote>It is good practice to include a Description that indicates the reason for the retraction or withdrawal.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/dateType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/descriptionType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
    <dcterms:identifier>descriptionType</dcterms:identifier>
    <dcterms:title>DataCite descriptionType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType/Abstract"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType/Methods"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType/Other"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType/SeriesInformation"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType/TableOfContents"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType/TechnicalInfo"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/descriptionType/Abstract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A brief description of the resource and the context in which the resource was created.</skos:definition>
    <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.1594/PANGAEA.771774</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
    <skos:notation>Abstract</skos:notation>
    <skos:prefLabel>Abstract</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery. Use “&lt;br&gt;” to indicate a line break for improved rendering of multiple paragraphs, but otherwise no html markup.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/descriptionType/Methods">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>The methodology employed for the study or research.</skos:definition>
    <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.6078/D1K01X</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
    <skos:notation>Methods</skos:notation>
    <skos:prefLabel>Methods</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery. Full documentation about methods supports open science.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/descriptionType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Other description information that does not fit into an existing category.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
    <skos:notation>Other</skos:notation>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:scopeNote>Use for any other description type.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/descriptionType/SeriesInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Information about a repeating series, such as volume, issue, number.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
    <skos:notation>SeriesInformation</skos:notation>
    <skos:prefLabel>SeriesInformation</skos:prefLabel>
    <skos:scopeNote>The information previously encoded as a description with this type should now be explicitly provided in tagged fields using the new RelatedItem property with relationType “IsPublishedIn” selected.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/descriptionType/TableOfContents">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A listing of the Table of Contents.</skos:definition>
    <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.5678/LCRS/FOR816.CIT.1031</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
    <skos:notation>TableOfContents</skos:notation>
    <skos:prefLabel>TableOfContents</skos:prefLabel>
    <skos:scopeNote>Use “&lt;br&gt;” to indicate a line break for improved rendering of multiple paragraphs, but otherwise no html markup.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/descriptionType/TechnicalInfo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Detailed information that may be associated with design, implementation, operation, use, and/or maintenance of a process, system, or instrument.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
    <skos:notation>TechnicalInfo</skos:notation>
    <skos:prefLabel>TechnicalInfo</skos:prefLabel>
    <skos:scopeNote>For software description, this may include the contents of a “readme.txt” and necessary environmental information (hardware, operational software, applications/programs with version information, a human-readable synopsis of software purpose) that cannot be described using other properties. For other uses, this can include specific and detailed information as necessary and appropriate.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/descriptionType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/funderIdentifierType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-12</dcterms:created>
    <dcterms:identifier>funderIdentifierType</dcterms:identifier>
    <dcterms:title>DataCite funderIdentifierType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType/CrossrefFunderID"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType/GRID"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType/ISNI"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType/Other"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType/ROR"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/funderIdentifierType/CrossrefFunderID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Crossref Funder Registry ID</skos:altLabel>
    <skos:definition>A persistent identifier for a funding body assigned by the Crossref Funder Registry, a curated, openly licensed registry of funder names and identifiers used to disambiguate funding organizations in scholarly metadata.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
    <skos:notation>Crossref Funder ID</skos:notation>
    <skos:prefLabel>Crossref Funder ID</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/funderIdentifierType/GRID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Global Research Identifier Database</skos:altLabel>
    <skos:definition>A persistent identifier for a research organization issued by the Global Research Identifier Database (GRID), a free database of research-related institution identifiers maintained by Digital Science.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
    <skos:notation>GRID</skos:notation>
    <skos:prefLabel>GRID</skos:prefLabel>
    <skos:scopeNote>GRID identifiers were succeeded by ROR identifiers in 2021; new records SHOULD prefer ROR where an equivalent ROR identifier exists.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/funderIdentifierType/ISNI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>International Standard Name Identifier</skos:altLabel>
    <skos:definition>A 16-character identifier for the public identity of a person or organization, defined by ISO 27729 and assigned by the ISNI International Agency. When used as a funder identifier, the ISNI uniquely identifies the funding organization.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
    <skos:notation>ISNI</skos:notation>
    <skos:prefLabel>ISNI</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/funderIdentifierType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Any funder identifier type not covered by the other values in the funderIdentifierType controlled list.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
    <skos:notation>Other</skos:notation>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:scopeNote>Use Other for funder identifier schemes that are not represented by a named value in this vocabulary. If a particular scheme is in common use, consider proposing it as a named value in a future DataCite release.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/funderIdentifierType/ROR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Research Organization Registry</skos:altLabel>
    <skos:definition>A persistent identifier for a research organization from the Research Organization Registry (ROR), a community-led, open registry of unique identifiers for every organization that performs, funds, or otherwise contributes to research.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
    <skos:notation>ROR</skos:notation>
    <skos:prefLabel>ROR</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/identifierType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-12</dcterms:created>
    <dcterms:identifier>identifierType</dcterms:identifier>
    <dcterms:title>DataCite identifierType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/identifierType/DOI"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/identifierType/DOI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Digital Object Identifier</skos:altLabel>
    <skos:definition>A character string used to uniquely and persistently identify a citable resource, registered with a DOI Registration Agency such as DataCite. A DOI name consists of a prefix (assigned to the registrant) and a suffix (assigned by the registrant to the resource), separated by a slash.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/identifierType"/>
    <skos:notation>DOI</skos:notation>
    <skos:prefLabel>DOI</skos:prefLabel>
    <skos:scopeNote>The DOI is the required identifier type for resources registered with DataCite; every DataCite record MUST carry exactly one DOI as its primary identifier.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/identifierType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/nameType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
    <dcterms:identifier>nameType</dcterms:identifier>
    <dcterms:title>DataCite nameType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/nameType/Organizational"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/nameType/Personal"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/nameType/Organizational">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>An organization or institution name.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/nameType"/>
    <skos:notation>Organizational</skos:notation>
    <skos:prefLabel>Organizational</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/nameType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/nameType/Personal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>An individual person’s name.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/nameType"/>
    <skos:notation>Personal</skos:notation>
    <skos:prefLabel>Personal</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/nameType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/numberType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-12</dcterms:created>
    <dcterms:identifier>numberType</dcterms:identifier>
    <dcterms:title>DataCite numberType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/numberType/Article"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/numberType/Chapter"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/numberType/Other"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/numberType/Report"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/numberType/Article">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A number identifying an article within a journal issue or proceedings volume.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/numberType"/>
    <skos:notation>Article</skos:notation>
    <skos:prefLabel>Article</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/numberType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/numberType/Chapter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A number identifying a chapter within a book or monograph.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/numberType"/>
    <skos:notation>Chapter</skos:notation>
    <skos:prefLabel>Chapter</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/numberType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/numberType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Any number type not covered by the other values in the numberType controlled list.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/numberType"/>
    <skos:notation>Other</skos:notation>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/numberType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/numberType/Report">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>A number identifying a report within a report series.</skos:definition>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/numberType"/>
    <skos:notation>Report</skos:notation>
    <skos:prefLabel>Report</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/numberType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
    <dcterms:identifier>relatedIdentifierType</dcterms:identifier>
    <dcterms:title>DataCite relatedIdentifierType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/ARK"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/CSTR"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/DOI"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/EAN13"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/EISSN"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/Handle"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/IGSN"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/ISBN"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/ISSN"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/ISTC"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/LISSN"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/LSID"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/PMID"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/PURL"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/RAiD"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/RRID"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/SWHID"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/UPC"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/URL"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/URN"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/arXiv"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/bibcode"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/w3id"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/ARK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Archival Resource Key</skos:altLabel>
    <skos:definition>A URI designed to support long-term access to information objects. In general, ARK syntax is of the form (brackets, []. indicate optional elements): [http://NMA/]ark:/NAAN/Name [Qualifier].</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="ARK" relationType="IsCitedBy"&gt;ark:/13030/tqb3kh97gh8w&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>ARK</skos:notation>
    <skos:prefLabel>ARK</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/CSTR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Common Science and Technology Resources Identifier</skos:altLabel>
    <skos:definition>CSTR is an identifier based on the Chinese National Standard GB/T 32843—2016 “Science and technology resource identification”, providing a unique identification service for scientific data, papers, scientific institutions, researchers, scientific instruments, patents and other scientific and technological resources.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="CSTR" relationType="References"&gt;31253.11.sciencedb.13238&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>CSTR</skos:notation>
    <skos:prefLabel>CSTR</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/DOI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Digital Object Identifier</skos:altLabel>
    <skos:definition>A character string used to uniquely identify an object. A DOI name is divided into two parts, a prefix and a suffix, separated by a slash.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsSupplementTo"&gt;10.1016/j.epsl.2011.11.037&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>DOI</skos:notation>
    <skos:prefLabel>DOI</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/EAN13">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>European Article Number (now renamed International Article Number, but retaining the original acronym)</skos:altLabel>
    <skos:definition>A 13-digit barcoding standard that is a superset of the original 12-digit Universal Product Code (UPC) system.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="EAN13" relationType="Cites"&gt;9783468111242&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>EAN13</skos:notation>
    <skos:prefLabel>EAN13</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/EISSN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Electronic International Standard Serial Number</skos:altLabel>
    <skos:definition>ISSN used to identify periodicals in electronic form (eISSN or e-ISSN).</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="eISSN" relationType="Cites"&gt;1562-6865&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>EISSN</skos:notation>
    <skos:prefLabel>EISSN</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/Handle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Handle</skos:altLabel>
    <skos:definition>This refers specifically to an ID in the Handle system operated by the Corporation for National Research Initiatives (CNRI).</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="Handle" relationType="References"&gt;10013/epic.10033&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>Handle</skos:notation>
    <skos:prefLabel>Handle</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/IGSN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>International Generic Sample Number</skos:altLabel>
    <skos:definition>A code that uniquely identifies samples from our natural environment and related features-of-interest.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="IGSN" relationType="References"&gt;IECUR0097&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>IGSN</skos:notation>
    <skos:prefLabel>IGSN</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/ISBN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>International Standard Book Number</skos:altLabel>
    <skos:definition>A unique numeric book identifier. There are 2 formats: a 10-digit ISBN format and a 13-digit ISBN.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISBN" relationType="IsPartOf"&gt;978-3-905673-82-1&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>ISBN</skos:notation>
    <skos:prefLabel>ISBN</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/ISSN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>International Standard Serial Number</skos:altLabel>
    <skos:definition>A unique 8-digit number used to identify a print or electronic periodical publication.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISSN" relationType="IsPartOf"&gt;0077-5606&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>ISSN</skos:notation>
    <skos:prefLabel>ISSN</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/ISTC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>International Standard Text Code</skos:altLabel>
    <skos:definition>A unique “number” assigned to a textual work. An ISTC consists of 16 numbers and/or letters.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISTC" relationType="Cites"&gt;0A9 2002 12B4A105 7&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>ISTC</skos:notation>
    <skos:prefLabel>ISTC</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/LISSN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Linking ISSN</skos:altLabel>
    <skos:definition>The linking ISSN or ISSN-L enables collocation or linking among different media versions of a continuing resource.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="LISSN" relationType="Cites"&gt;1188-1534&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>LISSN</skos:notation>
    <skos:prefLabel>LISSN</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/LSID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Life Science Identifiers</skos:altLabel>
    <skos:definition>A unique identifier for data in the Life Science domain. Format: urn:lsid:authority:namespace:identifier:revision.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="LSID" relationType="Cites"&gt;urn:lsid:ubio.org:namebank:11815&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>LSID</skos:notation>
    <skos:prefLabel>LSID</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/PMID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>PubMed identifier</skos:altLabel>
    <skos:definition>A unique number assigned to each PubMed record.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="PMID" relationType="IsReferencedBy"&gt;12082125&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>PMID</skos:notation>
    <skos:prefLabel>PMID</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/PURL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Persistent Uniform Resource Locator</skos:altLabel>
    <skos:definition>A PURL has three parts: (1) a protocol, (2) a resolver address, and (3) a name.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="PURL" relationType="Cites"&gt;http://purl.oclc.org/foo/bar&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>PURL</skos:notation>
    <skos:prefLabel>PURL</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/RAiD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Research Activity Identifier</skos:altLabel>
    <skos:definition>The Research Activity Identifier (RAiD) is a persistent identifier (PID) and global registry dedicated to research projects. RAiD is governed by ISO standard 23527:2022, with the Australian Research Data Commons (ARDC) as the Registration Authority and lead developer of the system. RAiD provides a system to store, update, share, and link project information across the research community.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="RAiD" relationType="IsPartOf" resourceTypeGeneral="Project"&gt;https://raid.org/10.26259/5c43ca8f&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>RAiD</skos:notation>
    <skos:prefLabel>RAiD</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/RRID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Research Resource IDentifier</skos:altLabel>
    <skos:definition>A character string used to uniquely identify key inputs to an experiment including the so-called “key biological resources” as defined by the National Institutes of Health, and related tools such as core facilities and databases. An RRID name is divided into two parts, the authority and a local identifier, separated by an underscore.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="RRID" relationType="Cites"&gt;RRID:SCR_014641&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>RRID</skos:notation>
    <skos:prefLabel>RRID</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/SWHID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>SoftWare Hash Identifier</skos:altLabel>
    <skos:definition>SWHIDs (from "SoftWare Hash IDentifiers") are persistent, intrinsic identifiers for software source code artifacts such as source code files, source trees, commits, and other objects typically found in version control systems.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="SWHID" relationType="Cites"&gt;swh:1:cnt:94a9ed024d3859793618152ea559a168bbcbb5e2&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>SWHID</skos:notation>
    <skos:prefLabel>SWHID</skos:prefLabel>
    <skos:scopeNote>A SWHID consists of two separate parts, a mandatory core identifier that can point to any software artifact (or "object") available in the Software Heritage archive, and an optional list of qualifiers that allows to specify the context where the object is meant to be seen and point to a subpart of the object itself.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/UPC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Universal Product Code</skos:altLabel>
    <skos:definition>A barcode symbology used for tracking trade items in stores. Its most common form, the UPC-A, consists of 12 numerical digits.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="UPC" relationType="Cites"&gt;123456789999&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>UPC</skos:notation>
    <skos:prefLabel>UPC</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/URL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Uniform Resource Locator</skos:altLabel>
    <skos:definition>Also known as web address, a URL is a specific character string that constitutes a reference to a resource. The syntax is: scheme://domain:port/path?query_string#fragment_id.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsCitedBy"&gt;http://www.heatflow.und.edu/index2.html&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>URL</skos:notation>
    <skos:prefLabel>URL</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/URN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Uniform Resource Name</skos:altLabel>
    <skos:definition>A unique and persistent identifier of an electronic document. The syntax is: urn:&lt;NID&gt;:&lt;NSS&gt;. The leading urn: sequence is case-insensitive, &lt;NID&gt; is the namespace identifier, &lt;NSS&gt; is the namespace-specific string.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="IsSupplementTo"&gt;urn:nbn:de:101:1-201102033592&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>URN</skos:notation>
    <skos:prefLabel>URN</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/arXiv">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>arXiv identifier</skos:altLabel>
    <skos:definition>arXiv.org is a repository of preprints of scientific papers in the fields of mathematics, physics, astronomy, computer science, quantitative biology, statistics, and quantitative finance.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="arXiv" relationType="IsCitedBy"&gt;arXiv:0706.0001&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>arXiv</skos:notation>
    <skos:prefLabel>arXiv</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/bibcode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Astrophysics Data System bibliographic codes</skos:altLabel>
    <skos:definition>A standardized 19-character identifier according to the syntax yyyyjjjjjvvvvmppppa. See http://info-uri.info/registry/OAIHandler?verb=GetRecord&amp;metadataPrefix=reg&amp;identifier=info:bibcode/. Note: bibcodes can be searched via https://ui.adsabs.harvard.edu/ or resolved using https://ui.adsabs.harvard.edu/abs/&lt;bibcode&gt;.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="bibcode" relationType="IsCitedBy"&gt;2018AGUFM.A24K..07S&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>bibcode</skos:notation>
    <skos:prefLabel>bibcode</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relatedIdentifierType/w3id">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:altLabel>Permanent identifier for Web applications</skos:altLabel>
    <skos:definition>Mostly used to publish vocabularies and ontologies. The letters ‘w3’ stand for “World Wide Web”.</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="w3id" relationType="IsCitedBy"&gt;https://w3id.org/games/spec/coil#Coil_Bomb_Die_Of_Age&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
    <skos:notation>w3id</skos:notation>
    <skos:prefLabel>w3id</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/relationType">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
    <dcterms:identifier>relationType</dcterms:identifier>
    <dcterms:title>DataCite relationType</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Cites"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Collects"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Compiles"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Continues"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Describes"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Documents"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/HasMetadata"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/HasPart"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/HasTranslation"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/HasVersion"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsCitedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsCollectedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsCompiledBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsContinuedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsDerivedFrom"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsDescribedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsDocumentedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsIdenticalTo"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsMetadataFor"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsNewVersionOf"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsObsoletedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsOriginalFormOf"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsPartOf"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsPreviousVersionOf"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsPublishedIn"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsReferencedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsRequiredBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsReviewedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsSourceOf"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsSupplementTo"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsSupplementedBy"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsTranslationOf"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsVariantFormOf"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/IsVersionOf"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Obsoletes"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Other"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/References"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Requires"/>
    <skos:hasTopConcept rdf:resource="https://w3id.org/tib/datacite/vocab/relationType/Reviews"/>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Cites">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates that A includes B in a citation</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISBN" relationType="Cites"&gt;0761964312&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Cites</skos:notation>
    <skos:prefLabel>Cites</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Collects">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Indicates A collects B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Collects"&gt;10.5072/data&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Collects</skos:notation>
    <skos:prefLabel>Collects</skos:prefLabel>
    <skos:scopeNote>May indicate relationship between an instrument and a dataset it collected/observed.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Compiles">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates B is the result of a compile or creation event using A</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="Compiles"&gt;urn:nbn:de:bsz:21-opus-963&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Compiles</skos:notation>
    <skos:prefLabel>Compiles</skos:prefLabel>
    <skos:scopeNote>May be used for software and text; a compiler can be a computer program or a person.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Continues">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is a continuation of the work B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="Continues"&gt;urn:nbn:de:bsz:21-opus-4966&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Continues</skos:notation>
    <skos:prefLabel>Continues</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Describes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A describes B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Describes"&gt;10.6084/m9.figshare.c.3288407&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Describes</skos:notation>
    <skos:prefLabel>Describes</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Documents">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is documentation about/explaining B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Documents"&gt;10.1234/7836&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Documents</skos:notation>
    <skos:prefLabel>Documents</skos:prefLabel>
    <skos:scopeNote>May be used for software documentation.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/HasMetadata">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates resource A has additional metadata B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="HasMetadata" relatedMetadataScheme="DDI-L" schemeURI="http://www.ddialliance.org/Specification/DDI-Lifecycle/3.1/XMLSchema/instance.xsd"&gt;10.1234/567890&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>HasMetadata</skos:notation>
    <skos:prefLabel>HasMetadata</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/HasPart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A includes the part B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="HasPart"&gt;https://zenodo.org/record/16564/files/dune-stuff-LSSC_15.zip&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>HasPart</skos:notation>
    <skos:prefLabel>HasPart</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery. Primarily applied to container-contained relationships. May be used for individual software modules; code repository-to-version should use IsVersionOf/HasVersion.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/HasTranslation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A has a translation B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="HasTranslation"&gt;10.21384/g01j-jm06&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>HasTranslation</skos:notation>
    <skos:prefLabel>HasTranslation</skos:prefLabel>
    <skos:scopeNote>When a resource is shared in one language and later translated, use HasTranslation to link original to translation. If released simultaneously in multiple languages, connect in both directions.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/HasVersion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A has a version B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="HasVersion"&gt;10.5281/ZENODO.832053&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>HasVersion</skos:notation>
    <skos:prefLabel>HasVersion</skos:prefLabel>
    <skos:scopeNote>The registered resource such as a software package or code repository has a versioned instance (A has instance B). May relate an un-versioned code repository to a specific software version.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsCitedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates that B includes A in a citation</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsCitedBy"&gt;10.4232/10.ASEAS-5.2-1&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsCitedBy</skos:notation>
    <skos:prefLabel>IsCitedBy</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsCollectedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Indicates A is collected by B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsCollectedBy"&gt;10.5072/instrument&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsCollectedBy</skos:notation>
    <skos:prefLabel>IsCollectedBy</skos:prefLabel>
    <skos:scopeNote>May indicate relationship between a dataset and an instrument used to collect/measure/observe data.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsCompiledBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates B is used to compile or create A</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsCompiledBy"&gt;http://d-nb.info/gnd/4513749-3&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsCompiledBy</skos:notation>
    <skos:prefLabel>IsCompiledBy</skos:prefLabel>
    <skos:scopeNote>May indicate a traditional text compilation, or the compiler program used to generate executable software.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsContinuedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is continued by the work B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="IsContinuedBy"&gt;urn:nbn:de:bsz:21-opus-4967&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsContinuedBy</skos:notation>
    <skos:prefLabel>IsContinuedBy</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsDerivedFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates B is a source upon which A is based</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsDerivedFrom"&gt;10.6078/M7DZ067C&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsDerivedFrom</skos:notation>
    <skos:prefLabel>IsDerivedFrom</skos:prefLabel>
    <skos:scopeNote>Use for a resource that is a derivative of an original resource. Example context: dataset derived from a larger dataset and manipulated.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsDescribedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is described by B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsDescribedBy"&gt;10.1038/sdata.2016.123&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsDescribedBy</skos:notation>
    <skos:prefLabel>IsDescribedBy</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsDocumentedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates B is documentation about/explaining A</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsDocumentedBy"&gt;http://tobias-lib.uni-tuebingen.de/volltexte/2000/96/&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsDocumentedBy</skos:notation>
    <skos:prefLabel>IsDocumentedBy</skos:prefLabel>
    <skos:scopeNote>May be used for software documentation.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsIdenticalTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates that A is identical to B, for use when there is a need to register two separate instances of the same resource</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsIdenticalTo"&gt;http://oac.cdlib.org/findaid/ark:/13030/c8r78fzq&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsIdenticalTo</skos:notation>
    <skos:prefLabel>IsIdenticalTo</skos:prefLabel>
    <skos:scopeNote>Use when the same resource is saved in another location (e.g., another institution).</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsMetadataFor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates additional metadata A for a resource B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsMetadataFor" relatedMetadataScheme="DDI-L" schemeURI="http://www.ddialliance.org/Specification/DDI-Lifecycle/3.1/XMLSchema/instance.xsd"&gt;10.1234/567891&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsMetadataFor</skos:notation>
    <skos:prefLabel>IsMetadataFor</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsNewVersionOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is a new edition of B, where the new edition has been modified or updated</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsNewVersionOf"&gt;10.5438/0005&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsNewVersionOf</skos:notation>
    <skos:prefLabel>IsNewVersionOf</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsObsoletedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Indicates A is replaced by B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsObsoletedBy"&gt;10.5438/0005&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsObsoletedBy</skos:notation>
    <skos:prefLabel>IsObsoletedBy</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsOriginalFormOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is the original form of B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsOriginalFormOf"&gt;10.1234/9035&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsOriginalFormOf</skos:notation>
    <skos:prefLabel>IsOriginalFormOf</skos:prefLabel>
    <skos:scopeNote>May be used for different software operating systems or compiler formats.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsPartOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is a portion of B; may be used for elements of a series</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsPartOf"&gt;10.5281/zenodo.754312&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsPartOf</skos:notation>
    <skos:prefLabel>IsPartOf</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery. Primarily applied to container-contained relationships. May be used for individual software modules; code repository-to-version should use IsVersionOf/HasVersion.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsPreviousVersionOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is a previous edition of B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsPreviousVersionOf"&gt;10.5438/0007&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsPreviousVersionOf</skos:notation>
    <skos:prefLabel>IsPreviousVersionOf</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsPublishedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is published inside B, but is independent of other things published inside of B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="ISSN" relationType="IsPublishedIn"&gt;2213-1337&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsPublishedIn</skos:notation>
    <skos:prefLabel>IsPublishedIn</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsReferencedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is used as a source of information by B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsReferencedBy"&gt;http://www.testpubl.de&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsReferencedBy</skos:notation>
    <skos:prefLabel>IsReferencedBy</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsRequiredBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Indicates A is required by B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsRequiredBy"&gt;10.1234/8675&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsRequiredBy</skos:notation>
    <skos:prefLabel>IsRequiredBy</skos:prefLabel>
    <skos:scopeNote>May be used to indicate software dependencies.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsReviewedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates that A is reviewed by B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsReviewedBy"&gt;10.5256/F1000RESEARCH.4288.R4745&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsReviewedBy</skos:notation>
    <skos:prefLabel>IsReviewedBy</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsSourceOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is a source upon which B is based</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URL" relationType="IsSourceOf"&gt;http://opencontext.org/projects/81204AF8-127C-4686-E9B0-1202C3A47959&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsSourceOf</skos:notation>
    <skos:prefLabel>IsSourceOf</skos:prefLabel>
    <skos:scopeNote>IsSourceOf is the original resource from which a derivative resource was created (e.g., original dataset without value manipulation).</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsSupplementTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates that A is a supplement to B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="IsSupplementTo"&gt;urn:nbn:de:0168-ssoar-13172&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsSupplementTo</skos:notation>
    <skos:prefLabel>IsSupplementTo</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsSupplementedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates that B is a supplement to A</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="PMID" relationType="IsSupplementedBy"&gt;16911322&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsSupplementedBy</skos:notation>
    <skos:prefLabel>IsSupplementedBy</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsTranslationOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is a translation of B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsTranslationOf"&gt;10.21384/828a-cm38&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsTranslationOf</skos:notation>
    <skos:prefLabel>IsTranslationOf</skos:prefLabel>
    <skos:scopeNote>When a resource is shared in one language and later translated, use IsTranslationOf to link translation to original.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsVariantFormOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is a variant or different form of B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsVariantFormOf"&gt;10.1234/8675&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsVariantFormOf</skos:notation>
    <skos:prefLabel>IsVariantFormOf</skos:prefLabel>
    <skos:scopeNote>Use for a different form of one thing. May be used for different software operating systems or compiler formats.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/IsVersionOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates A is a version of B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="IsVersionOf"&gt;10.5281/ZENODO.832054&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>IsVersionOf</skos:notation>
    <skos:prefLabel>IsVersionOf</skos:prefLabel>
    <skos:scopeNote>The registered resource is an instance of a target resource (A is an instance of B). May relate a specific software version to its code repository.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Obsoletes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Indicates A replaces B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Obsoletes"&gt;10.5438/0007&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Obsoletes</skos:notation>
    <skos:prefLabel>Obsoletes</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates that A is related to B and the relationship does not fit into an existing category</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Other" relationTypeInformation="is output of" resourceTypeGeneral="Project"&gt;10.21384/p27z-6n52&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Other</skos:notation>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:scopeNote>If selected, supply a value for relationTypeInformation describing the nature of the relationship; applies to both relatedIdentifier and relatedItem.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/References">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates B is used as a source of information for A</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="URN" relationType="References"&gt;urn:nbn:de:bsz:21-opus-963&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>References</skos:notation>
    <skos:prefLabel>References</skos:prefLabel>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Requires">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>Indicates A requires B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Requires"&gt;10.1234/867&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Requires</skos:notation>
    <skos:prefLabel>Requires</skos:prefLabel>
    <skos:scopeNote>May be used to indicate software dependencies.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://w3id.org/tib/datacite/vocab/relationType/Reviews">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:definition>indicates that A is a review of B</skos:definition>
    <skos:example>&lt;relatedIdentifier relatedIdentifierType="DOI" relationType="Reviews"&gt;10.12688/f1000research.4001.1&lt;/relatedIdentifier&gt;</skos:example>
    <skos:inScheme rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
    <skos:notation>Reviews</skos:notation>
    <skos:prefLabel>Reviews</skos:prefLabel>
    <skos:topConceptOf rdf:resource="https://w3id.org/tib/datacite/vocab/relationType"/>
  </skos:Concept>
  <skos:ConceptScheme rdf:about="https://w3id.org/tib/datacite/vocab/resourceTypeGeneral">
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
    <dcterms:identifier>resourceTypeGeneral</dcterms:identifier>
    <dcterms:title>DataCite resourceTypeGeneral</dcterms:title>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
