        rdfs:label    "description"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/description.jsonld> .

<https://w3id.org/tib/datacite/property/dateType>
        rdf:type      rdf:Property;
        rdfs:comment  "The type of date."@en;
        rdfs:label    "dateType"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/dateType.jsonld> .

<https://w3id.org/tib/datacite/property/dateInformation>
        rdf:type      rdf:Property;
        rdfs:comment  "Specific information about the date, if appropriate."@en;
        rdfs:label    "dateInformation"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/dateInformation.jsonld> .

<https://w3id.org/tib/datacite/property/date>
        rdf:type      rdf:Property;
        rdfs:comment  "Different dates relevant to the work."@en;
        rdfs:label    "date"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/date.jsonld> .

<https://w3id.org/tib/datacite/property/creatorName>
        rdf:type      rdf:Property;
        rdfs:comment  "The full name of the creator."@en;
        rdfs:label    "creatorName"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/creatorName.jsonld> .

<https://w3id.org/tib/datacite/property/creator>
        rdf:type      rdf:Property;
        rdfs:comment  "The main researchers involved in producing the data, or the authors of the publication, in priority order. For instruments this is the manufacturer or developer of the instrument. To supply multiple creators, repeat this property."@en;
        rdfs:label    "creator"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/creator.jsonld> .

<https://w3id.org/tib/datacite/property/contributorType>
        rdf:type      rdf:Property;
        rdfs:comment  "The type of contributor of the resource."@en;
        rdfs:label    "contributorType"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/contributorType.jsonld> .

<https://w3id.org/tib/datacite/property/contributorName>
        rdf:type      rdf:Property;
        rdfs:comment  "The full name of the contributor."@en;
        rdfs:label    "contributorName"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/contributorName.jsonld> .

<https://w3id.org/tib/datacite/property/contributor>
        rdf:type      rdf:Property;
        rdfs:comment  "The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property."@en;
        rdfs:label    "contributor"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/contributor.jsonld> .

<https://w3id.org/tib/datacite/property/classificationCode>
        rdf:type      rdf:Property;
        rdfs:comment  "The classification code used for the subject term in the subject scheme."@en;
        rdfs:label    "classificationCode"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/classificationCode.jsonld> .

<https://w3id.org/tib/datacite/property/awardURI>
        rdf:type      rdf:Property;
        rdfs:comment  "The URI leading to a page provided by the funder for more information about the award (grant)."@en;
        rdfs:label    "awardURI"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/awardURI.jsonld> .

<https://w3id.org/tib/datacite/property/awardTitle>
        rdf:type      rdf:Property;
        rdfs:comment  "The human readable title or name of the award (grant)."@en;
