        rdfs:label    "funderIdentifierType"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/funderIdentifierType.jsonld> .

<https://w3id.org/tib/datacite/property/funderIdentifier>
        rdf:type      rdf:Property;
        rdfs:comment  "Uniquely identifies a funding entity, according to various types."@en;
