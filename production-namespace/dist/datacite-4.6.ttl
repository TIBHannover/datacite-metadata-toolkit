<https://w3id.org/tib/datacite/property/awardNumber>
        rdf:type      rdf:Property;
        rdfs:comment  "The code assigned by the funder to a sponsored award (grant)."@en;
        rdfs:label    "awardNumber"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/awardNumber.jsonld> .

<https://w3id.org/tib/datacite/property/alternateIdentifierType>
        rdf:type      rdf:Property;
        rdfs:comment  "The type of the AlternateIdentifier."@en;
        rdfs:label    "alternateIdentifierType"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/alternateIdentifierType.jsonld> .

<https://w3id.org/tib/datacite/property/alternateIdentifier>
        rdf:type      rdf:Property;
        rdfs:comment  "An identifier or identifiers other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string unique within its domain of issue, such as a local identifier, a serial number of an instrument, or an inventory number."@en;
        rdfs:label    "alternateIdentifier"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/alternateIdentifier.jsonld> .

<https://w3id.org/tib/datacite/property/affiliationIdentifierScheme>
        rdf:type      rdf:Property;
        rdfs:comment  "The name of the affiliation identifier scheme"@en;
        rdfs:label    "affiliationIdentifierScheme"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/affiliationIdentifierScheme.jsonld> .

<https://w3id.org/tib/datacite/property/affiliationIdentifier>
        rdf:type      rdf:Property;
        rdfs:comment  "Uniquely identifies the organizational affiliation of the creator."@en;
        rdfs:label    "affiliationIdentifier"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/affiliationIdentifier.jsonld> .

<https://w3id.org/tib/datacite/property/affiliation>
        rdf:type      rdf:Property;
        rdfs:comment  "The organizational or institutional affiliation of the creator."@en;
        rdfs:label    "affiliation"@en;
        rdfs:seeAlso  <https://w3id.org/tib/datacite/property/affiliation.jsonld> .

<https://w3id.org/tib/datacite/dist/datacite-4.6>
        rdf:type            owl:Ontology;
        rdfs:comment        "Integrated distribution of the DataCite linked-data classes, properties, vocabulary schemes, and vocabulary terms for schema version 4.6."@en;
        rdfs:seeAlso        <https://w3id.org/tib/datacite/dist/datacite-4.6.rdf> , <https://w3id.org/tib/datacite/dist/datacite-4.6.ttl> , <https://w3id.org/tib/datacite/dist/datacite-4.6.jsonld>;
        dcterms:created     "2026-06-16"^^xsd:date;
        dcterms:identifier  "datacite-4.6";
