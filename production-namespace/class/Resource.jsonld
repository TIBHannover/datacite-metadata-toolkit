{
  "@context": {
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "schema": "https://w3id.org/tib/datacite/",
    "datacite": "https://w3id.org/tib/datacite/"
  },
  "@id": "https://w3id.org/tib/datacite/class/Resource",
  "@type": "rdfs:Class",
  "rdfs:label": "Resource",
  "rdfs:comment": "Any object (data, software, instrument, document, sample, etc.) that can be cited via a DataCite-assigned persistent identifier (DOI). This is the root class of the DataCite Metadata Schema; every DataCite record describes exactly one Resource."
}