  "type": "Concept",
  "prefLabel": "IsPartOf",
  "notation": "IsPartOf",
  "definition": "indicates A is a portion of B; may be used for elements of a series",
  "inScheme": "https://w3id.org/tib/datacite/vocab/relationType",
  "topConceptOf": "https://w3id.org/tib/datacite/vocab/relationType",
  "scopeNote": "Recommended for discovery. Primarily applied to container-contained relationships. May be used for individual software modules; code repository-to-version should use IsVersionOf/HasVersion.",
  "example": [
    "<relatedIdentifier relatedIdentifierType=\"DOI\" relationType=\"IsPartOf\">10.5281/zenodo.754312</relatedIdentifier>"
  ]
