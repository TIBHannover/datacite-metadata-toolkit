<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Date">
    <rdfs:label>Date</rdfs:label>
    <rdfs:comment>Different dates relevant to the work.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/publisherIdentifierScheme">
    <rdfs:label>publisherIdentifierScheme</rdfs:label>
    <rdfs:comment>The name of the publisher identifier scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/pointLatitude">
    <rdfs:label>pointLatitude</rdfs:label>
    <rdfs:comment>Latitudinal dimension of point.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Subject">
    <rdfs:label>Subject</rdfs:label>
    <rdfs:comment>Subject, keyword, classification code, or key phrase describing the resource.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/polygonPoint">
    <rdfs:label>polygonPoint</rdfs:label>
    <rdfs:comment>A point location in a polygon.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/publicationYear">
    <rdfs:label>publicationYear</rdfs:label>
    <rdfs:comment>The year when the item was or will be made publicly available.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Creator">
    <rdfs:label>Creator</rdfs:label>
    <rdfs:comment>The main researchers involved in producing the data, or the authors of the publication, in priority order. For instruments this is the manufacturer or developer of the instrument. To supply multiple creators, repeat this property.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/GeoLocation">
    <rdfs:label>GeoLocation</rdfs:label>
    <rdfs:comment>Spatial region or named place where the data was gathered or about which the data is focused.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/inPolygonPoint">
    <rdfs:label>inPolygonPoint</rdfs:label>
    <rdfs:comment>A point location in a polygon.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocation">
    <rdfs:label>geoLocation</rdfs:label>
    <rdfs:comment>Spatial region or named place where the data was gathered or about which the data is focused.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/alternateIdentifierType">
    <rdfs:label>alternateIdentifierType</rdfs:label>
    <rdfs:comment>The type of the AlternateIdentifier.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/RelatedIdentifier">
    <rdfs:label>RelatedIdentifier</rdfs:label>
    <rdfs:comment>Identifiers of related resources. These must be globally unique identifiers.</rdfs:comment>
  </rdfs:Class>
  <owl:Ontology rdf:about="https://w3id.org/tib/datacite/dist/datacite">
    <owl:versionIRI rdf:resource="https://w3id.org/tib/datacite/dist/datacite-4.7"/>
    <owl:versionInfo>4.7</owl:versionInfo>
    <dcterms:title xml:lang="en">DataCite Linked Data Ontology 4.7</dcterms:title>
    <dcterms:description xml:lang="en">OWL representation of the DataCite linked-data vocabulary for DataCite Metadata Schema 4.7.</dcterms:description>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-18</dcterms:created>
    <dcterms:source rdf:resource="https://w3id.org/tib/datacite/manifest/datacite-4.7.json"/>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:contributor rdf:resource="https://github.com/selgebali"/>
    <dcterms:contributor rdf:resource="https://github.com/DenizJaeger"/>
  </owl:Ontology>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Resource">
    <rdfs:label>Resource</rdfs:label>
    <rdfs:comment>Any object (data, software, instrument, document, sample, etc.) that can be cited via a DataCite-assigned persistent identifier (DOI). This is the root class of the DataCite Metadata Schema; every DataCite record describes exactly one Resource.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/rightsURI">
    <rdfs:label>rightsURI</rdfs:label>
    <rdfs:comment>The URI of the license.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/size">
    <rdfs:label>size</rdfs:label>
    <rdfs:comment>Size (e.g., bytes, pages, inches, etc.) or duration (extent), e.g., hours, minutes, days, etc., of a resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocationBox">
    <rdfs:label>geoLocationBox</rdfs:label>
    <rdfs:comment>The spatial limits of a box.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocationPoint">
    <rdfs:label>geoLocationPoint</rdfs:label>
    <rdfs:comment>A point location in space.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/numberType">
    <rdfs:label>numberType</rdfs:label>
    <rdfs:comment>Type of the related item’s number, e.g., report number or article number.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedItemIdentifierType">
    <rdfs:label>relatedItemIdentifierType</rdfs:label>
    <rdfs:comment>The type of the Identifier for the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/funderIdentifier">
    <rdfs:label>funderIdentifier</rdfs:label>
    <rdfs:comment>Uniquely identifies a funding entity, according to various types.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/eastBoundLongitude">
    <rdfs:label>eastBoundLongitude</rdfs:label>
    <rdfs:comment>Eastern longitudinal dimension of box.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/publisherIdentifier">
    <rdfs:label>publisherIdentifier</rdfs:label>
    <rdfs:comment>Uniquely identifies the publisher, according to various schemes.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/volume">
    <rdfs:label>volume</rdfs:label>
    <rdfs:comment>Volume of the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/dateType">
    <rdfs:label>dateType</rdfs:label>
    <rdfs:comment>The type of date.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Description">
    <rdfs:label>Description</rdfs:label>
    <rdfs:comment> All additional information that does not fit in any of the other categories. May be used for technical information or detailed information associated with a scientific instrument.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedItemIdentifier">
    <rdfs:label>relatedItemIdentifier</rdfs:label>
    <rdfs:comment>The identifier for the related item.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Publisher">
    <rdfs:label>Publisher</rdfs:label>
    <rdfs:comment>The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/date">
    <rdfs:label>date</rdfs:label>
    <rdfs:comment>Different dates relevant to the work.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Format">
    <rdfs:label>Format</rdfs:label>
    <rdfs:comment>Technical format of the resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/PublicationYear">
    <rdfs:label>PublicationYear</rdfs:label>
    <rdfs:comment>The year when the data was or will be made publicly available. In the case of resources such as software or dynamic data where there may be multiple releases in one year, include the Date property and sub-properties (dateType/dateInformation) to provide more information about the publication or release date details.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocationPlace">
    <rdfs:label>geoLocationPlace</rdfs:label>
    <rdfs:comment>Description of a geographic location.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Size">
    <rdfs:label>Size</rdfs:label>
    <rdfs:comment>Size (e.g., bytes, pages, inches, etc.) or duration (extent), e.g., hours, minutes, days, etc., of a resource.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/ResourceType">
    <rdfs:label>ResourceType</rdfs:label>
    <rdfs:comment>A description of the resource.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/rightsIdentifier">
    <rdfs:label>rightsIdentifier</rdfs:label>
    <rdfs:comment>A short standardized identifier for the licence.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/language">
    <rdfs:label>language</rdfs:label>
    <rdfs:comment>The primary language of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/titleType">
    <rdfs:label>titleType</rdfs:label>
    <rdfs:comment>The type of Title (other than the Main Title).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/contributorType">
    <rdfs:label>contributorType</rdfs:label>
    <rdfs:comment>The type of contributor of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/version">
    <rdfs:label>version</rdfs:label>
    <rdfs:comment>The version number of the resource.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Identifier">
    <rdfs:label>Identifier</rdfs:label>
    <rdfs:comment>The Identifier is a unique string that identifies a resource.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/awardNumber">
    <rdfs:label>awardNumber</rdfs:label>
    <rdfs:comment>The code assigned by the funder to a sponsored award (grant).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/dateInformation">
    <rdfs:label>dateInformation</rdfs:label>
    <rdfs:comment>Specific information about the date, if appropriate.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/fundingReference">
    <rdfs:label>fundingReference</rdfs:label>
    <rdfs:comment>Information about financial support (funding) for the resource being registered.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relationTypeInformation">
    <rdfs:label>relationTypeInformation</rdfs:label>
    <rdfs:comment>Additional information about the selected relationType, if appropriate.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/resourceTypeGeneral">
    <rdfs:label>resourceTypeGeneral</rdfs:label>
    <rdfs:comment>The general type of a resource.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Language">
    <rdfs:label>Language</rdfs:label>
    <rdfs:comment>The primary language of the resource.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/awardTitle">
    <rdfs:label>awardTitle</rdfs:label>
    <rdfs:comment>The human readable title or name of the award (grant).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/valueURI">
    <rdfs:label>valueURI</rdfs:label>
    <rdfs:comment> The URI of the subject term.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/subjectScheme">
    <rdfs:label>subjectScheme</rdfs:label>
    <rdfs:comment>The name of the subject scheme or classification code or authority if one is used.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/format">
    <rdfs:label>format</rdfs:label>
    <rdfs:comment>Technical format of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/subject">
    <rdfs:label>subject</rdfs:label>
    <rdfs:comment>Subject, keyword, classification code, or key phrase describing the resource.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Rights">
    <rdfs:label>Rights</rdfs:label>
    <rdfs:comment>Any rights information for this resource.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/familyName">
    <rdfs:label>familyName</rdfs:label>
    <rdfs:comment>The surname or last name of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/nameIdentifierScheme">
    <rdfs:label>nameIdentifierScheme</rdfs:label>
    <rdfs:comment>The name of the name identifier scheme.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/RelatedItem">
    <rdfs:label>RelatedItem</rdfs:label>
    <rdfs:comment>Information about a resource related to the one being registered.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/affiliationIdentifier">
    <rdfs:label>affiliationIdentifier</rdfs:label>
    <rdfs:comment>Uniquely identifies the organizational affiliation of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/pointLongitude">
    <rdfs:label>pointLongitude</rdfs:label>
    <rdfs:comment>Longitudinal dimension of point.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/resourceType">
    <rdfs:label>resourceType</rdfs:label>
    <rdfs:comment>A description of the resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/awardURI">
    <rdfs:label>awardURI</rdfs:label>
    <rdfs:comment>The URI leading to a page provided by the funder for more information about the award (grant).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedIdentifier">
    <rdfs:label>relatedIdentifier</rdfs:label>
    <rdfs:comment>Identifiers of related resources. These must be globally unique identifiers.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/edition">
    <rdfs:label>edition</rdfs:label>
    <rdfs:comment>Edition or version of the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/descriptionType">
    <rdfs:label>descriptionType</rdfs:label>
    <rdfs:comment>The type of the Description.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedIdentifierType">
    <rdfs:label>relatedIdentifierType</rdfs:label>
    <rdfs:comment>The type of the RelatedIdentifier.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/funderName">
    <rdfs:label>funderName</rdfs:label>
    <rdfs:comment>Name of the funding provider.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/title">
    <rdfs:label>title</rdfs:label>
    <rdfs:comment>A name or title by which a resource is known. May be the title of a dataset or the name of a piece of software or an instrument.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/geoLocationPolygon">
    <rdfs:label>geoLocationPolygon</rdfs:label>
    <rdfs:comment>A drawn polygon area, defined by a set of points and lines connecting the points in a closed chain.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/affiliationIdentifierScheme">
    <rdfs:label>affiliationIdentifierScheme</rdfs:label>
    <rdfs:comment>The name of the affiliation identifier scheme</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/affiliation">
    <rdfs:label>affiliation</rdfs:label>
    <rdfs:comment>The organizational or institutional affiliation of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/creatorName">
    <rdfs:label>creatorName</rdfs:label>
    <rdfs:comment>The full name of the creator.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedItemType">
    <rdfs:label>relatedItemType</rdfs:label>
    <rdfs:comment>The general type of the related item.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Contributor">
    <rdfs:label>Contributor</rdfs:label>
    <rdfs:comment> The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property. For software, if there is an alternate entity that “holds, archives, publishes, prints, distributes, releases, issues, or produces” the code, use the contributorType “HostingInstitution” for the code repository. For instruments, if there is an institution responsible for the management of the instrument (for example, the legal owner, the operator, or an institute providing access to the instrument), use the contributorType “HostingInstitution” for the owner of the instrument.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/publisher">
    <rdfs:label>publisher</rdfs:label>
    <rdfs:comment>The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/westBoundLongitude">
    <rdfs:label>westBoundLongitude</rdfs:label>
    <rdfs:comment>Western longitudinal dimension of box.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/rightsIdentifierScheme">
    <rdfs:label>rightsIdentifierScheme</rdfs:label>
    <rdfs:comment>The name of the scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/number">
    <rdfs:label>number</rdfs:label>
    <rdfs:comment>Number of the resource within the related item, e.g., report number or article number.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/contributor">
    <rdfs:label>contributor</rdfs:label>
    <rdfs:comment>The institution or person responsible for collecting, managing, distributing, or otherwise contributing to the development of the resource. To supply multiple contributors, repeat this property.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedMetadataScheme">
    <rdfs:label>relatedMetadataScheme</rdfs:label>
    <rdfs:comment>The name of the scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/issue">
    <rdfs:label>issue</rdfs:label>
    <rdfs:comment>Issue number or name of the related item.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/alternateIdentifier">
    <rdfs:label>alternateIdentifier</rdfs:label>
    <rdfs:comment>An identifier or identifiers other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string unique within its domain of issue, such as a local identifier, a serial number of an instrument, or an inventory number.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/nameType">
    <rdfs:label>nameType</rdfs:label>
    <rdfs:comment>The type of name.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relatedItem">
    <rdfs:label>relatedItem</rdfs:label>
    <rdfs:comment>Information about a resource related to the one being registered.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Version">
    <rdfs:label>Version</rdfs:label>
    <rdfs:comment>The version number of the resource.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/funderIdentifierType">
    <rdfs:label>funderIdentifierType</rdfs:label>
    <rdfs:comment>The type of the funderIdentifier.</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/Title">
    <rdfs:label>Title</rdfs:label>
    <rdfs:comment>A name or title by which a resource is known. May be the title of a dataset or the name of a piece of software or an instrument.</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/identifier">
    <rdfs:label>identifier</rdfs:label>
    <rdfs:comment>The Identifier is a unique string that identifies a resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/relationType">
    <rdfs:label>relationType</rdfs:label>
    <rdfs:comment>Description of the relationship of the resource being registered (A) and the related resource (B).</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/rights">
    <rdfs:label>rights</rdfs:label>
    <rdfs:comment>Any rights information for this resource.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/identifierType">
    <rdfs:label>identifierType</rdfs:label>
    <rdfs:comment>The type of Identifier.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/northBoundLatitude">
    <rdfs:label>northBoundLatitude</rdfs:label>
    <rdfs:comment>Northern latitudinal dimension of box.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/description">
    <rdfs:label>description</rdfs:label>
    <rdfs:comment>All additional information that does not fit in any of the other categories. May be used for technical information or detailed information associated with a scientific instrument.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/nameIdentifier">
    <rdfs:label>nameIdentifier</rdfs:label>
    <rdfs:comment>Uniquely identifies an individual or legal entity, according to various schemes.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/contributorName">
    <rdfs:label>contributorName</rdfs:label>
    <rdfs:comment>The full name of the contributor.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/firstPage">
    <rdfs:label>firstPage</rdfs:label>
    <rdfs:comment>First page of the resource within the related item, e.g., of the chapter, article, or conference paper in proceedings.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/creator">
    <rdfs:label>creator</rdfs:label>
    <rdfs:comment>The main researchers involved in producing the data, or the authors of the publication, in priority order. For instruments this is the manufacturer or developer of the instrument. To supply multiple creators, repeat this property.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/southBoundLatitude">
    <rdfs:label>southBoundLatitude</rdfs:label>
    <rdfs:comment>Southern latitude of box .</rdfs:comment>
  </rdf:Property>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/FundingReference">
    <rdfs:label>FundingReference</rdfs:label>
    <rdfs:comment>Information about financial support (funding) for the resource being registered.</rdfs:comment>
  </rdfs:Class>
  <rdfs:Class rdf:about="https://schema.stage.datacite.org/linked-data/class/AlternateIdentifier">
    <rdfs:label>AlternateIdentifier</rdfs:label>
    <rdfs:comment>An identifier other than the primary Identifier applied to the resource being registered. This may be any alphanumeric string which is unique within its domain of issue. May be used for local identifiers, a serial number of an instrument or an inventory number. The AlternateIdentifier should be an additional identifier for the same instance of the resource (i.e., same location, same file).</rdfs:comment>
  </rdfs:Class>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/classificationCode">
    <rdfs:label>classificationCode</rdfs:label>
    <rdfs:comment>The classification code used for the subject term in the subject scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/schemeURI">
    <rdfs:label>schemeURI</rdfs:label>
    <rdfs:comment>The URI of an identifier scheme.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/lastPage">
    <rdfs:label>lastPage</rdfs:label>
    <rdfs:comment>Last page of the resource within the related item, e.g., of the chapter, article, or conference paper in proceedings.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/schemeType">
    <rdfs:label>schemeType</rdfs:label>
    <rdfs:comment>The type of the relatedMetadataScheme, linked with the schemeURI.</rdfs:comment>
  </rdf:Property>
  <rdf:Property rdf:about="https://schema.stage.datacite.org/linked-data/property/givenName">
    <rdfs:label>givenName</rdfs:label>
    <rdfs:comment>The personal or first name of the creator.</rdfs:comment>
  </rdf:Property>
  <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <dcterms:title>DataCite 4.6 resourceTypeGeneral</dcterms:title>
    <dcterms:identifier>resourceTypeGeneral</dcterms:identifier>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Audiovisual">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Audiovisual</skos:prefLabel>
        <skos:notation>Audiovisual</skos:notation>
        <skos:definition>A series of visual representations imparting an impression of motion when shown in succession. May or may not include sound.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>May be used for films, video, etc.</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.17608/k6.auckland.4620790.v1</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#MovingImage"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Award">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Award</skos:prefLabel>
        <skos:notation>Award</skos:notation>
        <skos:definition>An umbrella term for resources provided to individual(s) or organization(s) in support of research, academic output, or training, such as a specific instance of funding, grant, investment, sponsorship, scholarship, recognition, or non-monetary materials.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="Award">Grant</resourceType>
<resourceType resourceTypeGeneral="Award">Facility use</resourceType>]]></skos:scopeNote>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Book">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Book</skos:prefLabel>
        <skos:notation>Book</skos:notation>
        <skos:definition>A medium for recording information in the form of writing or images, typically composed of many pages bound together and protected by a cover.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="Book">Textbook</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/BookChapter">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>BookChapter</skos:prefLabel>
        <skos:notation>BookChapter</skos:notation>
        <skos:definition>One of the main divisions of a book.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.15122/isbn.978-2-406-09313-8.p.0639</skos:example>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.17613/m6631d</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Collection">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Collection</skos:prefLabel>
        <skos:notation>Collection</skos:notation>
        <skos:definition>An aggregation of resources, which may encompass collections of one resourceType as well as those of mixed types. A collection is described as a group; its parts may also be separately described.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>A collection of samples, or various files making up a report</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.1594/pangaea.877589</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Collection"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ComputationalNotebook">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>ComputationalNotebook</skos:prefLabel>
        <skos:notation>ComputationalNotebook</skos:notation>
        <skos:definition>A virtual notebook environment used for literate programming.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="ComputationalNotebook">Jupyter</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#InteractiveResource"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ConferencePaper">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>ConferencePaper</skos:prefLabel>
        <skos:notation>ConferencePaper</skos:notation>
        <skos:definition>Article that is written with the goal of being accepted to a conference.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="ConferencePaper">Experience Report</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/ConferenceProceeding">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>ConferenceProceeding</skos:prefLabel>
        <skos:notation>ConferenceProceeding</skos:notation>
        <skos:definition>Collection of academic papers published in the context of an academic conference.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="ConferenceProceeding">Annual Convention</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/DataPaper">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>DataPaper</skos:prefLabel>
        <skos:notation>DataPaper</skos:notation>
        <skos:definition>A factual and objective publication with a focused intent to identify and describe specific data, sets of data, or data collections to facilitate discoverability.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>A data paper describes data provenance and methodologies used in the gathering, processing, organizing, and representing the data</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.17912/w2mw2d</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Dataset">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Dataset</skos:prefLabel>
        <skos:notation>Dataset</skos:notation>
        <skos:definition>Data encoded in a defined structure.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Data file or files</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.1594/pangaea.804876</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Dataset"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Dissertation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Dissertation</skos:prefLabel>
        <skos:notation>Dissertation</skos:notation>
        <skos:definition>A written essay, treatise, or thesis, especially one written by a candidate for the degree of Doctor of Philosophy.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="Dissertation">PhD thesis</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Event">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Event</skos:prefLabel>
        <skos:notation>Event</skos:notation>
        <skos:definition>A non-persistent, time-based occurrence.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Descriptive information and/or content that is the basis for discovery of the purpose, location, duration, and responsible agents associated with an event such as a webcast or convention</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.7269/p3rn35sz</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Event"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Image">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Image</skos:prefLabel>
        <skos:notation>Image</skos:notation>
        <skos:definition>A visual representation other than text.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Digitised or born digital images, drawings or photographs</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.6083/m4qn65c5</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Image"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Instrument">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Instrument</skos:prefLabel>
        <skos:notation>Instrument</skos:notation>
        <skos:definition>A device, tool or apparatus used to obtain, measure and/or analyze data.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[This is meant to be the instrument instance (the individual physical device), not the digital description or design of an instrument.
<resourceType resourceTypeGeneral="Instrument">Reflectometer</resourceType>]]></skos:scopeNote>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/InteractiveResource">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>InteractiveResource</skos:prefLabel>
        <skos:notation>InteractiveResource</skos:notation>
        <skos:definition>A resource requiring interaction from the user to be understood, executed, or experienced.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Training modules, files that require use of a viewer (e.g., Flash), or query/response portals</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.7269/p3tb14tr</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#InteractiveResource"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Journal">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Journal</skos:prefLabel>
        <skos:notation>Journal</skos:notation>
        <skos:definition>A scholarly publication consisting of articles that is published regularly throughout the year.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="Journal"></resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/JournalArticle">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>JournalArticle</skos:prefLabel>
        <skos:notation>JournalArticle</skos:notation>
        <skos:definition>A written composition on a topic of interest, which forms a separate part of a journal.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="JournalArticle"></resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Model">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Model</skos:prefLabel>
        <skos:notation>Model</skos:notation>
        <skos:definition>An abstract, conceptual, graphical, mathematical or visualization model that represents empirical objects, phenomena, or physical processes.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Modelled descriptions of, for example, different aspects of languages or a molecular biology reaction chain</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.5285/4d866cd2-c907-4ce2-b070-084ca9779dc2</skos:example>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/OutputManagementPlan">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>OutputManagementPlan</skos:prefLabel>
        <skos:notation>OutputManagementPlan</skos:notation>
        <skos:definition>A formal document that outlines how research outputs are to be handled both during a research project and after the project is completed.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[Includes data, software, and materials.
<resourceType resourceTypeGeneral="OutputManagementPlan">Data Management Plan</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/PeerReview">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>PeerReview</skos:prefLabel>
        <skos:notation>PeerReview</skos:notation>
        <skos:definition>Evaluation of scientific, academic, or professional work by others working in the same field.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.6084/m9.figshare.5742270
<resourceType resourceTypeGeneral="PeerReview">Scientific Article</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/PhysicalObject">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>PhysicalObject</skos:prefLabel>
        <skos:notation>PhysicalObject</skos:notation>
        <skos:definition>A physical object or substance.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Artifacts, specimens, material samples, and features-of-interest of any size. Digital representations of physical objects should use one of the other resourceTypeGeneral values.</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.7299/X78052RB</skos:example>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Poster">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Poster</skos:prefLabel>
        <skos:notation>Poster</skos:notation>
        <skos:definition>A display poster, typically containing text with illustrative figures and/or tables, usually reporting research results or proposing hypotheses, submitted for acceptance to and/or presented at a conference, seminar, symposium, workshop or similar event.</skos:definition>
        <skos:scopeNote>Posters may be physical or digital.</skos:scopeNote>
        <skos:example><![CDATA[<resourceType resourceTypeGeneral="Poster">Conference poster</resourceType>]]></skos:example>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Preprint">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Preprint</skos:prefLabel>
        <skos:notation>Preprint</skos:notation>
        <skos:definition>A version of a scholarly or scientific paper that precedes formal peer review and publication in a peer-reviewed scholarly or scientific journal.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="Preprint">Research Paper</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Presentation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Presentation</skos:prefLabel>
        <skos:notation>Presentation</skos:notation>
        <skos:definition>A set of slides containing text, tables or figures, designed to communicate ideas or research results, for viewing by an audience at a conference, symposium, seminar, lecture, workshop or other event.</skos:definition>
        <skos:scopeNote>For a video recording of a presentation, use "Audiovisual".</skos:scopeNote>
        <skos:example><![CDATA[<resourceType resourceTypeGeneral="Presentation">Conference presentation slides</resourceType>]]></skos:example>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Project">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Project</skos:prefLabel>
        <skos:notation>Project</skos:notation>
        <skos:definition>A planned endeavor or activity, frequently collaborative, intended to achieve a particular aim using allocated resources such as budget, time, and expertise.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[This represents the project (research projects and studies). For project deliverables/descriptions, use the resource type for the output.
<resourceType resourceTypeGeneral="Project">Field season</resourceType>
<resourceType resourceTypeGeneral="Project">Cohort study</resourceType>]]></skos:scopeNote>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Report">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Report</skos:prefLabel>
        <skos:notation>Report</skos:notation>
        <skos:definition>A document that presents information in an organized format for a specific audience and purpose.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="Report">Annual Report</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Service">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Service</skos:prefLabel>
        <skos:notation>Service</skos:notation>
        <skos:definition>An organized system of apparatus, appliances, staff, etc., for supplying some function(s) required by end users.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Data management service, or long-term preservation service</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.21938/3I01ISNUCODNH1ZJBCVUWA</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Service"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Software">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Software</skos:prefLabel>
        <skos:notation>Software</skos:notation>
        <skos:definition>A computer program other than a computational notebook, in either source code (text) or compiled form. Use this type for general software components supporting scholarly research. Use the ComputationalNotebook value for virtual notebooks.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Software supporting scholarly research</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.4225/03/5954F738EE5AA</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Software"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Sound">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Sound</skos:prefLabel>
        <skos:notation>Sound</skos:notation>
        <skos:definition>A resource primarily intended to be heard.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Audio recording</skos:scopeNote>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.7282/T3J67F05</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Sound"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Standard">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Standard</skos:prefLabel>
        <skos:notation>Standard</skos:notation>
        <skos:definition>Something established by authority, custom, or general consent as a model, example, or point of reference.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[<resourceType resourceTypeGeneral="Standard">Dublin Core</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/StudyRegistration">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>StudyRegistration</skos:prefLabel>
        <skos:notation>StudyRegistration</skos:notation>
        <skos:definition>A detailed, time-stamped description of a research plan, often openly shared in a registry or published in a journal before the study is conducted to lend accountability and transparency in the hypothesis generating and testing process.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote><![CDATA[Includes pre-registrations, registered reports, and clinical trials. Study registrations are sometimes peer-reviewed and may include the hypothesis, expected results, study design, and/or analysis plan.
<resourceType resourceTypeGeneral="StudyRegistration">Pre-registration</resourceType>]]></skos:scopeNote>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Text">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Text</skos:prefLabel>
        <skos:notation>Text</skos:notation>
        <skos:definition>A resource consisting primarily of words for reading that is not covered by any other textual resource type in this list.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:example>https://api.datacite.org/dois/application/vnd.datacite.datacite+xml/10.5682/9786065914018</skos:example>
        <skos:closeMatch rdf:resource="https://www.dublincore.org/specifications/dublin-core/dcmi-type-vocabulary/#Text"/>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Workflow">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Workflow</skos:prefLabel>
        <skos:notation>Workflow</skos:notation>
        <skos:definition>A structured series of steps which can be executed to produce a final outcome, allowing users a means to specify and enact their work in a more reproducible manner.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:scopeNote>Computational workflows involving sequential operations made on data by wrapped software and may be specified in a format belonging to a workflow management system, such as Taverna (http://www.taverna.org.uk/).</skos:scopeNote>
      </skos:Concept>
    </skos:hasTopConcept>
    <skos:hasTopConcept>
      <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral/Other">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <skos:prefLabel>Other</skos:prefLabel>
        <skos:notation>Other</skos:notation>
        <skos:definition>If selected, supply a value for ResourceType.</skos:definition>
        <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
        <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/resourceTypeGeneral"/>
      </skos:Concept>
    </skos:hasTopConcept>
  </skos:ConceptScheme>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectLeader">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ProjectLeader</skos:prefLabel>
    <skos:notation>ProjectLeader</skos:notation>
    <skos:definition>Person officially designated as head of project team or sub-project team instrumental in the work necessary to development of the resource.</skos:definition>
    <skos:scopeNote>The Project Leader remains intimately involved throughout the life of the particular project team.</skos:scopeNote>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 contributorType</dcterms:title>
        <dcterms:identifier>contributorType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-18</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ContactPerson"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCollector"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCurator"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataManager"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Distributor"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Editor"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/HostingInstitution"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Producer"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectLeader"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectManager"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectMember"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAgency"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAuthority"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RelatedPerson"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Researcher"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ResearchGroup"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RightsHolder"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Sponsor"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Supervisor"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Translator"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/WorkPackageLeader"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Other"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Methods">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Methods</skos:prefLabel>
    <skos:notation>Methods</skos:notation>
    <skos:definition>The methodology employed for the study or research.</skos:definition>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 descriptionType</dcterms:title>
        <dcterms:identifier>descriptionType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Abstract"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Methods"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/SeriesInformation"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TableOfContents"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TechnicalInfo"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Other"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:scopeNote>Recommended for discovery. Full documentation about methods supports open science.</skos:scopeNote>
    <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.6078/D1K01X</skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Reviews">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Reviews</skos:prefLabel>
    <skos:notation>Reviews</skos:notation>
    <skos:definition>indicates that A is a review of B</skos:definition>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 relationType</dcterms:title>
        <dcterms:identifier>relationType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCitedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Cites"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSupplementTo"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSupplementedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsContinuedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Continues"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Describes"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDescribedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasMetadata"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsMetadataFor"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasVersion"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVersionOf"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsNewVersionOf"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPreviousVersionOf"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPartOf"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasPart"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPublishedIn"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReferencedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/References"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDocumentedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Documents"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCompiledBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Compiles"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVariantFormOf"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsOriginalFormOf"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsIdenticalTo"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReviewedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Reviews"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDerivedFrom"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSourceOf"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsRequiredBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Requires"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Obsoletes"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsObsoletedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCollectedBy"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Collects"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsTranslationOf"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasTranslation"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType/Other"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="Reviews">10.12688/f1000research.4001.1</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsOriginalFormOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsOriginalFormOf</skos:prefLabel>
    <skos:notation>IsOriginalFormOf</skos:notation>
    <skos:definition>indicates A is the original form of B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May be used for different software operating systems or compiler formats.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsOriginalFormOf">10.1234/9035</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Collects">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Collects</skos:prefLabel>
    <skos:notation>Collects</skos:notation>
    <skos:definition>Indicates A collects B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May indicate relationship between an instrument and a dataset it collected/observed.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="Collects">10.5072/data</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsTranslationOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsTranslationOf</skos:prefLabel>
    <skos:notation>IsTranslationOf</skos:notation>
    <skos:definition>indicates A is a translation of B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>When a resource is shared in one language and later translated, use IsTranslationOf to link translation to original.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsTranslationOf">10.21384/828a-cm38</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:notation>Other</skos:notation>
    <skos:definition>indicates that A is related to B and the relationship does not fit into an existing category</skos:definition>
    <skos:scopeNote>If selected, supply a value for relationTypeInformation describing the nature of the relationship; applies to both relatedIdentifier and relatedItem.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="Other" relationTypeInformation="is output of" resourceTypeGeneral="Project">10.21384/p27z-6n52</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Created">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Created</skos:prefLabel>
    <skos:notation>Created</skos:notation>
    <skos:definition>The date the resource itself was put together; this could refer to a timeframe in ancient history, a date range, or a single date for a final component, e.g., the finalised file with all the data.</skos:definition>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 dateType</dcterms:title>
        <dcterms:identifier>dateType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Accepted"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Available"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Copyrighted"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Collected"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Coverage"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Created"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Issued"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Submitted"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Updated"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Valid"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Withdrawn"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType/Other"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Obsoletes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Obsoletes</skos:prefLabel>
    <skos:notation>Obsoletes</skos:notation>
    <skos:definition>Indicates A replaces B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="Obsoletes">10.5438/0007</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPublishedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsPublishedIn</skos:prefLabel>
    <skos:notation>IsPublishedIn</skos:notation>
    <skos:definition>indicates A is published inside B, but is independent of other things published inside of B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="ISSN" relationType="IsPublishedIn">2213-1337</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ARK">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ARK</skos:prefLabel>
    <skos:altLabel>Archival Resource Key</skos:altLabel>
    <skos:notation>ARK</skos:notation>
    <skos:definition>A URI designed to support long-term access to information objects. In general, ARK syntax is of the form (brackets, []. indicate optional elements): [http://NMA/]ark:/NAAN/Name [Qualifier].</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="ARK" relationType="IsCitedBy">ark:/13030/tqb3kh97gh8w</relatedIdentifier>]]></skos:example>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 relatedIdentifierType</dcterms:title>
        <dcterms:identifier>relatedIdentifierType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ARK"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/arXiv"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/bibcode"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/CSTR"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/DOI"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EAN13"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EISSN"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/Handle"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/IGSN"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISBN"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISSN"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISTC"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LISSN"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LSID"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PMID"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PURL"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RAiD"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RRID"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/SWHID"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/UPC"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URL"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URN"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/w3id"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Describes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Describes</skos:prefLabel>
    <skos:notation>Describes</skos:notation>
    <skos:definition>indicates A describes B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="Describes">10.6084/m9.figshare.c.3288407</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Producer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Producer</skos:prefLabel>
    <skos:notation>Producer</skos:notation>
    <skos:definition>Typically, a person or organisation responsible for the artistry and form of a media product.</skos:definition>
    <skos:scopeNote>In the data industry, this may be a company producing DVDs that package data for future dissemination by a distributor.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/arXiv">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>arXiv</skos:prefLabel>
    <skos:altLabel>arXiv identifier</skos:altLabel>
    <skos:notation>arXiv</skos:notation>
    <skos:definition>arXiv.org is a repository of preprints of scientific papers in the fields of mathematics, physics, astronomy, computer science, quantitative biology, statistics, and quantitative finance.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="arXiv" relationType="IsCitedBy">arXiv:0706.0001</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReferencedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsReferencedBy</skos:prefLabel>
    <skos:notation>IsReferencedBy</skos:notation>
    <skos:definition>indicates A is used as a source of information by B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URL" relationType="IsReferencedBy">http://www.testpubl.de</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectMember">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ProjectMember</skos:prefLabel>
    <skos:notation>ProjectMember</skos:notation>
    <skos:definition>Person on the membership list of a designated project/project team.</skos:definition>
    <skos:scopeNote>This vocabulary may or may not indicate the quality, quantity, or substance of the person’s involvement.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Withdrawn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Withdrawn</skos:prefLabel>
    <skos:notation>Withdrawn</skos:notation>
    <skos:definition>The date the resource is removed.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:scopeNote>It is good practice to include a Description that indicates the reason for the retraction or withdrawal.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/CSTR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>CSTR</skos:prefLabel>
    <skos:altLabel>Common Science and Technology Resources Identifier</skos:altLabel>
    <skos:notation>CSTR</skos:notation>
    <skos:definition>CSTR is an identifier based on the Chinese National Standard GB/T 32843—2016 “Science and technology resource identification”, providing a unique identification service for scientific data, papers, scientific institutions, researchers, scientific instruments, patents and other scientific and technological resources.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="CSTR" relationType="References">31253.11.sciencedb.13238</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/bibcode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>bibcode</skos:prefLabel>
    <skos:altLabel>Astrophysics Data System bibliographic codes</skos:altLabel>
    <skos:notation>bibcode</skos:notation>
    <skos:definition><![CDATA[A standardized 19-character identifier according to the syntax yyyyjjjjjvvvvmppppa. See http://info-uri.info/registry/OAIHandler?verb=GetRecord&metadataPrefix=reg&identifier=info:bibcode/. Note: bibcodes can be searched via https://ui.adsabs.harvard.edu/ or resolved using https://ui.adsabs.harvard.edu/abs/<bibcode>.]]></skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="bibcode" relationType="IsCitedBy">2018AGUFM.A24K..07S</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RightsHolder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>RightsHolder</skos:prefLabel>
    <skos:notation>RightsHolder</skos:notation>
    <skos:definition>Person or institution owning or managing property rights, including intellectual property rights over the resource.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LSID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>LSID</skos:prefLabel>
    <skos:altLabel>Life Science Identifiers</skos:altLabel>
    <skos:notation>LSID</skos:notation>
    <skos:definition>A unique identifier for data in the Life Science domain. Format: urn:lsid:authority:namespace:identifier:revision.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="LSID" relationType="Cites">urn:lsid:ubio.org:namebank:11815</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/HostingInstitution">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>HostingInstitution</skos:prefLabel>
    <skos:notation>HostingInstitution</skos:notation>
    <skos:definition>Typically, the organisation allowing the resource to be available on the internet through the provision of its hardware/software/operating support.</skos:definition>
    <skos:scopeNote>This role normally falls on the university, research center, or organization where the data center/repository belongs. May also be used for an organisation that stores the data offline, often a data centre if that data centre is not the publisher.</skos:scopeNote>
    <skos:example>Université Grenoble Alpes (UGA)</skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISSN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ISSN</skos:prefLabel>
    <skos:altLabel>International Standard Serial Number</skos:altLabel>
    <skos:notation>ISSN</skos:notation>
    <skos:definition>A unique 8-digit number used to identify a print or electronic periodical publication.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="ISSN" relationType="IsPartOf">0077-5606</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/nameType/Personal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Personal</skos:prefLabel>
    <skos:notation>Personal</skos:notation>
    <skos:definition>An individual person’s name.</skos:definition>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/nameType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 nameType</dcterms:title>
        <dcterms:identifier>nameType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-20</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType/Organizational"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType/Personal"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Available">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Available</skos:prefLabel>
    <skos:notation>Available</skos:notation>
    <skos:definition>The date the resource is made publicly available. May be a range.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:scopeNote>To indicate the end of an embargo period, use Available.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/References">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>References</skos:prefLabel>
    <skos:notation>References</skos:notation>
    <skos:definition>indicates B is used as a source of information for A</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URN" relationType="References">urn:nbn:de:bsz:21-opus-963</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/GRID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>GRID</skos:prefLabel>
    <skos:altLabel>Global Research Identifier Database</skos:altLabel>
    <skos:notation>GRID</skos:notation>
    <skos:definition>A persistent identifier for a research organization issued by the Global Research Identifier Database (GRID), a free database of research-related institution identifiers maintained by Digital Science.</skos:definition>
    <skos:scopeNote>GRID identifiers were succeeded by ROR identifiers in 2021; new records SHOULD prefer ROR where an equivalent ROR identifier exists.</skos:scopeNote>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 funderIdentifierType</dcterms:title>
        <dcterms:identifier>funderIdentifierType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-12</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/CrossrefFunderID"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/GRID"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/ISNI"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/ROR"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/Other"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/LISSN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>LISSN</skos:prefLabel>
    <skos:altLabel>Linking ISSN</skos:altLabel>
    <skos:notation>LISSN</skos:notation>
    <skos:definition>The linking ISSN or ISSN-L enables collocation or linking among different media versions of a continuing resource.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="LISSN" relationType="Cites">1188-1534</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/identifierType/DOI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>DOI</skos:prefLabel>
    <skos:altLabel>Digital Object Identifier</skos:altLabel>
    <skos:notation>DOI</skos:notation>
    <skos:definition>A character string used to uniquely and persistently identify a citable resource, registered with a DOI Registration Agency such as DataCite. A DOI name consists of a prefix (assigned to the registrant) and a suffix (assigned by the registrant to the resource), separated by a slash.</skos:definition>
    <skos:scopeNote>The DOI is the required identifier type for resources registered with DataCite; every DataCite record MUST carry exactly one DOI as its primary identifier.</skos:scopeNote>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/identifierType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 identifierType</dcterms:title>
        <dcterms:identifier>identifierType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-12</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/identifierType/DOI"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/identifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSupplementTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsSupplementTo</skos:prefLabel>
    <skos:notation>IsSupplementTo</skos:notation>
    <skos:definition>indicates that A is a supplement to B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URN" relationType="IsSupplementTo">urn:nbn:de:0168-ssoar-13172</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCollector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>DataCollector</skos:prefLabel>
    <skos:notation>DataCollector</skos:notation>
    <skos:definition>Person/institution responsible for finding or gathering/collecting data under the guidelines of the author(s) or Principal Investigator (PI).</skos:definition>
    <skos:scopeNote>May also be used when crediting survey conductors, interviewers, event or condition observers, or persons responsible for monitoring key instrument data.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/numberType/Chapter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Chapter</skos:prefLabel>
    <skos:notation>Chapter</skos:notation>
    <skos:definition>A number identifying a chapter within a book or monograph.</skos:definition>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/numberType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 numberType</dcterms:title>
        <dcterms:identifier>numberType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-12</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType/Article"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType/Chapter"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType/Report"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType/Other"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PMID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>PMID</skos:prefLabel>
    <skos:altLabel>PubMed identifier</skos:altLabel>
    <skos:notation>PMID</skos:notation>
    <skos:definition>A unique number assigned to each PubMed record.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="PMID" relationType="IsReferencedBy">12082125</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/SWHID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>SWHID</skos:prefLabel>
    <skos:altLabel>SoftWare Hash Identifier</skos:altLabel>
    <skos:notation>SWHID</skos:notation>
    <skos:definition>SWHIDs (from "SoftWare Hash IDentifiers") are persistent, intrinsic identifiers for software source code artifacts such as source code files, source trees, commits, and other objects typically found in version control systems.</skos:definition>
    <skos:scopeNote>A SWHID consists of two separate parts, a mandatory core identifier that can point to any software artifact (or "object") available in the Software Heritage archive, and an optional list of qualifiers that allows to specify the context where the object is meant to be seen and point to a subpart of the object itself.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="SWHID" relationType="Cites">swh:1:cnt:94a9ed024d3859793618152ea559a168bbcbb5e2</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDocumentedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsDocumentedBy</skos:prefLabel>
    <skos:notation>IsDocumentedBy</skos:notation>
    <skos:definition>indicates B is documentation about/explaining A</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May be used for software documentation.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URL" relationType="IsDocumentedBy">http://tobias-lib.uni-tuebingen.de/volltexte/2000/96/</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Issued">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Issued</skos:prefLabel>
    <skos:notation>Issued</skos:notation>
    <skos:definition>The date that the resource is published or distributed, e.g., to a data centre.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsObsoletedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsObsoletedBy</skos:prefLabel>
    <skos:notation>IsObsoletedBy</skos:notation>
    <skos:definition>Indicates A is replaced by B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsObsoletedBy">10.5438/0005</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:notation>Other</skos:notation>
    <skos:definition>Any funder identifier type not covered by the other values in the funderIdentifierType controlled list.</skos:definition>
    <skos:scopeNote>Use Other for funder identifier schemes that are not represented by a named value in this vocabulary. If a particular scheme is in common use, consider proposing it as a named value in a future DataCite release.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/ROR">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ROR</skos:prefLabel>
    <skos:altLabel>Research Organization Registry</skos:altLabel>
    <skos:notation>ROR</skos:notation>
    <skos:definition>A persistent identifier for a research organization from the Research Organization Registry (ROR), a community-led, open registry of unique identifiers for every organization that performs, funds, or otherwise contributes to research.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasMetadata">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>HasMetadata</skos:prefLabel>
    <skos:notation>HasMetadata</skos:notation>
    <skos:definition>indicates resource A has additional metadata B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="HasMetadata" relatedMetadataScheme="DDI-L" schemeURI="http://www.ddialliance.org/Specification/DDI-Lifecycle/3.1/XMLSchema/instance.xsd">10.1234/567890</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RAiD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>RAiD</skos:prefLabel>
    <skos:altLabel>Research Activity Identifier</skos:altLabel>
    <skos:notation>RAiD</skos:notation>
    <skos:definition>The Research Activity Identifier (RAiD) is a persistent identifier (PID) and global registry dedicated to research projects. RAiD is governed by ISO standard 23527:2022, with the Australian Research Data Commons (ARDC) as the Registration Authority and lead developer of the system. RAiD provides a system to store, update, share, and link project information across the research community.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="RAiD" relationType="IsPartOf" resourceTypeGeneral="Project">https://raid.org/10.26259/5c43ca8f</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/titleType/Subtitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Subtitle</skos:prefLabel>
    <skos:notation>Subtitle</skos:notation>
    <skos:definition>A secondary title that follows the main title and provides additional information about the resource.</skos:definition>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="https://schema.stage.datacite.org/linked-data/vocab/titleType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
        <dcterms:title>DataCite 4.6 titleType</dcterms:title>
        <dcterms:identifier>titleType</dcterms:identifier>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-12</dcterms:created>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType/AlternativeTitle"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType/Subtitle"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType/TranslatedTitle"/>
        <skos:hasTopConcept rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType/Other"/>
      </skos:ConceptScheme>
    </skos:inScheme>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Compiles">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Compiles</skos:prefLabel>
    <skos:notation>Compiles</skos:notation>
    <skos:definition>indicates B is the result of a compile or creation event using A</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May be used for software and text; a compiler can be a computer program or a person.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URN" relationType="Compiles">urn:nbn:de:bsz:21-opus-963</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ContactPerson">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ContactPerson</skos:prefLabel>
    <skos:notation>ContactPerson</skos:notation>
    <skos:definition>Person with knowledge of how to access, troubleshoot, or otherwise field issues related to the resource.</skos:definition>
    <skos:scopeNote>May also be the “Point of Contact” in an organisation that controls access to the resource, if that organisation is different from the Publisher, Distributor, and Data Manager.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/titleType/AlternativeTitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>AlternativeTitle</skos:prefLabel>
    <skos:notation>AlternativeTitle</skos:notation>
    <skos:definition>A title by which the resource is also known, used as an alternative to the primary title.</skos:definition>
    <skos:scopeNote>Use for formally recognized alternate titles. For translated titles use TranslatedTitle; for secondary titles use Subtitle.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAgency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>RegistrationAgency</skos:prefLabel>
    <skos:notation>RegistrationAgency</skos:notation>
    <skos:definition>Institution/organisation officially appointed by a Registration Authority to handle specific tasks within a defined area of responsibility.</skos:definition>
    <skos:scopeNote>DataCite is a Registration Agency for the International DOI Foundation (IDF). One task is to assign DOI prefixes to allocating agents who then assign full DOI strings to clients and provide metadata back to the DataCite registry.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/RRID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>RRID</skos:prefLabel>
    <skos:altLabel>Research Resource IDentifier</skos:altLabel>
    <skos:notation>RRID</skos:notation>
    <skos:definition>A character string used to uniquely identify key inputs to an experiment including the so-called “key biological resources” as defined by the National Institutes of Health, and related tools such as core facilities and databases. An RRID name is divided into two parts, the authority and a local identifier, separated by an underscore.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="RRID" relationType="Cites">RRID:SCR_014641</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Researcher">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Researcher</skos:prefLabel>
    <skos:notation>Researcher</skos:notation>
    <skos:definition>A person involved in analysing data or the results of an experiment or formal study.</skos:definition>
    <skos:scopeNote>Should be a person, not an institution. A person gathering data would typically be DataCollector. A researcher may find additional data online and correlate it to collected data.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Collected">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Collected</skos:prefLabel>
    <skos:notation>Collected</skos:notation>
    <skos:definition>The date or date range in which the resource content was collected.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:scopeNote>To indicate precise or particular timeframes in which research was conducted.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISTC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ISTC</skos:prefLabel>
    <skos:altLabel>International Standard Text Code</skos:altLabel>
    <skos:notation>ISTC</skos:notation>
    <skos:definition>A unique “number” assigned to a textual work. An ISTC consists of 16 numbers and/or letters.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="ISTC" relationType="Cites">0A9 2002 12B4A105 7</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RegistrationAuthority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>RegistrationAuthority</skos:prefLabel>
    <skos:notation>RegistrationAuthority</skos:notation>
    <skos:definition>A standards-setting body from which Registration Agencies obtain official recognition and guidance.</skos:definition>
    <skos:scopeNote>The IDF serves as the Registration Authority for the International Standards Organisation (ISO) in the area/domain of Digital Object Identifiers.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsMetadataFor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsMetadataFor</skos:prefLabel>
    <skos:notation>IsMetadataFor</skos:notation>
    <skos:definition>indicates additional metadata A for a resource B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsMetadataFor" relatedMetadataScheme="DDI-L" schemeURI="http://www.ddialliance.org/Specification/DDI-Lifecycle/3.1/XMLSchema/instance.xsd">10.1234/567891</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/UPC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>UPC</skos:prefLabel>
    <skos:altLabel>Universal Product Code</skos:altLabel>
    <skos:notation>UPC</skos:notation>
    <skos:definition>A barcode symbology used for tracking trade items in stores. Its most common form, the UPC-A, consists of 12 numerical digits.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="UPC" relationType="Cites">123456789999</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasPart">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>HasPart</skos:prefLabel>
    <skos:notation>HasPart</skos:notation>
    <skos:definition>indicates A includes the part B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Recommended for discovery. Primarily applied to container-contained relationships. May be used for individual software modules; code repository-to-version should use IsVersionOf/HasVersion.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URL" relationType="HasPart">https://zenodo.org/record/16564/files/dune-stuff-LSSC_15.zip</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsReviewedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsReviewedBy</skos:prefLabel>
    <skos:notation>IsReviewedBy</skos:notation>
    <skos:definition>indicates that A is reviewed by B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsReviewedBy">10.5256/F1000RESEARCH.4288.R4745</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Abstract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Abstract</skos:prefLabel>
    <skos:notation>Abstract</skos:notation>
    <skos:definition>A brief description of the resource and the context in which the resource was created.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:scopeNote><![CDATA[Recommended for discovery. Use “<br>” to indicate a line break for improved rendering of multiple paragraphs, but otherwise no html markup.]]></skos:scopeNote>
    <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.1594/PANGAEA.771774</skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/numberType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:notation>Other</skos:notation>
    <skos:definition>Any number type not covered by the other values in the numberType controlled list.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:notation>Other</skos:notation>
    <skos:definition>Other description information that does not fit into an existing category.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:scopeNote>Use for any other description type.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/ISBN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ISBN</skos:prefLabel>
    <skos:altLabel>International Standard Book Number</skos:altLabel>
    <skos:notation>ISBN</skos:notation>
    <skos:definition>A unique numeric book identifier. There are 2 formats: a 10-digit ISBN format and a 13-digit ISBN.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="ISBN" relationType="IsPartOf">978-3-905673-82-1</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataManager">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>DataManager</skos:prefLabel>
    <skos:notation>DataManager</skos:notation>
    <skos:definition>Person (or organisation with a staff of data managers, such as a data centre) responsible for maintaining the finished resource.</skos:definition>
    <skos:scopeNote>Ensures the resource is periodically refreshed (software/hardware support), kept available/protected from unauthorized access, stored according to industry standards, and handled according to applicable records management requirements.</skos:scopeNote>
    <skos:example>https://doi.org/10.6073/pasta/41b3ed2e152e1e4c3846e646118208e7</skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/WorkPackageLeader">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>WorkPackageLeader</skos:prefLabel>
    <skos:notation>WorkPackageLeader</skos:notation>
    <skos:definition>A Work Package is a recognized data product, not all of which is included in publication. The package may include notes, discarded documents, etc. The Work Package Leader is responsible for ensuring comprehensive contents, versioning, and availability of the Work Package during development of the resource.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>URN</skos:prefLabel>
    <skos:altLabel>Uniform Resource Name</skos:altLabel>
    <skos:notation>URN</skos:notation>
    <skos:definition><![CDATA[A unique and persistent identifier of an electronic document. The syntax is: urn:<NID>:<NSS>. The leading urn: sequence is case-insensitive, <NID> is the namespace identifier, <NSS> is the namespace-specific string.]]></skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URN" relationType="IsSupplementTo">urn:nbn:de:101:1-201102033592</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Requires">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Requires</skos:prefLabel>
    <skos:notation>Requires</skos:notation>
    <skos:definition>Indicates A requires B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May be used to indicate software dependencies.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="Requires">10.1234/867</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSourceOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsSourceOf</skos:prefLabel>
    <skos:notation>IsSourceOf</skos:notation>
    <skos:definition>indicates A is a source upon which B is based</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>IsSourceOf is the original resource from which a derivative resource was created (e.g., original dataset without value manipulation).</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URL" relationType="IsSourceOf">http://opencontext.org/projects/81204AF8-127C-4686-E9B0-1202C3A47959</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/ISNI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ISNI</skos:prefLabel>
    <skos:altLabel>International Standard Name Identifier</skos:altLabel>
    <skos:notation>ISNI</skos:notation>
    <skos:definition>A 16-character identifier for the public identity of a person or organization, defined by ISO 27729 and assigned by the ISNI International Agency. When used as a funder identifier, the ISNI uniquely identifies the funding organization.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TechnicalInfo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>TechnicalInfo</skos:prefLabel>
    <skos:notation>TechnicalInfo</skos:notation>
    <skos:definition>Detailed information that may be associated with design, implementation, operation, use, and/or maintenance of a process, system, or instrument.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:scopeNote>For software description, this may include the contents of a “readme.txt” and necessary environmental information (hardware, operational software, applications/programs with version information, a human-readable synopsis of software purpose) that cannot be described using other properties. For other uses, this can include specific and detailed information as necessary and appropriate.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPartOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsPartOf</skos:prefLabel>
    <skos:notation>IsPartOf</skos:notation>
    <skos:definition>indicates A is a portion of B; may be used for elements of a series</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Recommended for discovery. Primarily applied to container-contained relationships. May be used for individual software modules; code repository-to-version should use IsVersionOf/HasVersion.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsPartOf">10.5281/zenodo.754312</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCollectedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsCollectedBy</skos:prefLabel>
    <skos:notation>IsCollectedBy</skos:notation>
    <skos:definition>Indicates A is collected by B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May indicate relationship between a dataset and an instrument used to collect/measure/observe data.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsCollectedBy">10.5072/instrument</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ProjectManager">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ProjectManager</skos:prefLabel>
    <skos:notation>ProjectManager</skos:notation>
    <skos:definition>Person officially designated as manager of a project. Project may consist of one or many project teams and sub-teams.</skos:definition>
    <skos:scopeNote>The manager of a project normally has more administrative responsibility than actual work involvement.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:notation>Other</skos:notation>
    <skos:definition>Other date that does not fit into an existing category.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/ResearchGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>ResearchGroup</skos:prefLabel>
    <skos:notation>ResearchGroup</skos:notation>
    <skos:definition>Typically refers to a group of individuals with a lab, department, or division that has a specifically defined focus of activity.</skos:definition>
    <skos:scopeNote>May operate at a narrower level of scope; may or may not hold less administrative responsibility than a project team.</skos:scopeNote>
    <skos:example>Space Research &amp; Planetary Sciences Division of the University of Bern (WP Unibe)</skos:example>
    <skos:example>doi:10.26302/SSHADE/EXPERIMEN T_OP_20201104_001</skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/DOI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>DOI</skos:prefLabel>
    <skos:altLabel>Digital Object Identifier</skos:altLabel>
    <skos:notation>DOI</skos:notation>
    <skos:definition>A character string used to uniquely identify an object. A DOI name is divided into two parts, a prefix and a suffix, separated by a slash.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsSupplementTo">10.1016/j.epsl.2011.11.037</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Continues">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Continues</skos:prefLabel>
    <skos:notation>Continues</skos:notation>
    <skos:definition>indicates A is a continuation of the work B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URN" relationType="Continues">urn:nbn:de:bsz:21-opus-4966</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Supervisor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Supervisor</skos:prefLabel>
    <skos:notation>Supervisor</skos:notation>
    <skos:definition>Designated administrator over one or more groups/teams working to produce a resource, or over one or more steps of a development process.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCompiledBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsCompiledBy</skos:prefLabel>
    <skos:notation>IsCompiledBy</skos:notation>
    <skos:definition>indicates B is used to compile or create A</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May indicate a traditional text compilation, or the compiler program used to generate executable software.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URL" relationType="IsCompiledBy">http://d-nb.info/gnd/4513749-3</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/PURL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>PURL</skos:prefLabel>
    <skos:altLabel>Persistent Uniform Resource Locator</skos:altLabel>
    <skos:notation>PURL</skos:notation>
    <skos:definition>A PURL has three parts: (1) a protocol, (2) a resolver address, and (3) a name.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="PURL" relationType="Cites">http://purl.oclc.org/foo/bar</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/Handle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Handle</skos:prefLabel>
    <skos:altLabel>Handle</skos:altLabel>
    <skos:notation>Handle</skos:notation>
    <skos:definition>This refers specifically to an ID in the Handle system operated by the Corporation for National Research Initiatives (CNRI).</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="Handle" relationType="References">10013/epic.10033</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVariantFormOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsVariantFormOf</skos:prefLabel>
    <skos:notation>IsVariantFormOf</skos:notation>
    <skos:definition>indicates A is a variant or different form of B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Use for a different form of one thing. May be used for different software operating systems or compiler formats.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsVariantFormOf">10.1234/8675</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/numberType/Report">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Report</skos:prefLabel>
    <skos:notation>Report</skos:notation>
    <skos:definition>A number identifying a report within a report series.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Coverage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Coverage</skos:prefLabel>
    <skos:notation>Coverage</skos:notation>
    <skos:definition>The date or date range that the resource content applies to, describes, or covers.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:scopeNote>To indicate the temporal coverage of the resource, use Coverage. This may be different from Collected.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDerivedFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsDerivedFrom</skos:prefLabel>
    <skos:notation>IsDerivedFrom</skos:notation>
    <skos:definition>indicates B is a source upon which A is based</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Use for a resource that is a derivative of an original resource. Example context: dataset derived from a larger dataset and manipulated.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsDerivedFrom">10.6078/M7DZ067C</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/TableOfContents">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>TableOfContents</skos:prefLabel>
    <skos:notation>TableOfContents</skos:notation>
    <skos:definition>A listing of the Table of Contents.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:scopeNote><![CDATA[Use “<br>” to indicate a line break for improved rendering of multiple paragraphs, but otherwise no html markup.]]></skos:scopeNote>
    <skos:example>https://data.datacite.org/application/vnd.datacite.datacite+xml/10.5678/LCRS/FOR816.CIT.1031</skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsSupplementedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsSupplementedBy</skos:prefLabel>
    <skos:notation>IsSupplementedBy</skos:notation>
    <skos:definition>indicates that B is a supplement to A</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="PMID" relationType="IsSupplementedBy">16911322</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EISSN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>EISSN</skos:prefLabel>
    <skos:altLabel>Electronic International Standard Serial Number</skos:altLabel>
    <skos:notation>EISSN</skos:notation>
    <skos:definition>ISSN used to identify periodicals in electronic form (eISSN or e-ISSN).</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="eISSN" relationType="Cites">1562-6865</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:notation>Other</skos:notation>
    <skos:definition>Any person or institution making a significant contribution to the development and/or maintenance of the resource, but whose contribution is not adequately described by any of the other values for contributorType.</skos:definition>
    <skos:scopeNote>Could be a photographer, artist, or writer whose contribution helped to publicize the resource (as opposed to creating it), a reviewer, someone providing administrative services (depositing updates, analysing usage), etc.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/RelatedPerson">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>RelatedPerson</skos:prefLabel>
    <skos:notation>RelatedPerson</skos:notation>
    <skos:definition>A person without a specifically defined role in the development of the resource, but who is someone the author wishes to recognize.</skos:definition>
    <skos:scopeNote>Could be an author’s intellectual mentor, a person providing intellectual leadership in the discipline or subject domain, etc.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/nameType/Organizational">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Organizational</skos:prefLabel>
    <skos:notation>Organizational</skos:notation>
    <skos:definition>An organization or institution name.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/nameType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/EAN13">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>EAN13</skos:prefLabel>
    <skos:altLabel>European Article Number (now renamed International Article Number, but retaining the original acronym)</skos:altLabel>
    <skos:notation>EAN13</skos:notation>
    <skos:definition>A 13-digit barcoding standard that is a superset of the original 12-digit Universal Product Code (UPC) system.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="EAN13" relationType="Cites">9783468111242</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsCitedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsCitedBy</skos:prefLabel>
    <skos:notation>IsCitedBy</skos:notation>
    <skos:definition>indicates that B includes A in a citation</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsCitedBy">10.4232/10.ASEAS-5.2-1</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsContinuedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsContinuedBy</skos:prefLabel>
    <skos:notation>IsContinuedBy</skos:notation>
    <skos:definition>indicates A is continued by the work B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URN" relationType="IsContinuedBy">urn:nbn:de:bsz:21-opus-4967</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Valid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Valid</skos:prefLabel>
    <skos:notation>Valid</skos:notation>
    <skos:definition>The date or date range during which the dataset or resource is accurate.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Cites">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Cites</skos:prefLabel>
    <skos:notation>Cites</skos:notation>
    <skos:definition>indicates that A includes B in a citation</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Recommended for discovery.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="ISBN" relationType="Cites">0761964312</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Accepted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Accepted</skos:prefLabel>
    <skos:notation>Accepted</skos:notation>
    <skos:definition>The date that the publisher accepted the resource into their system.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:scopeNote>To indicate the start of an embargo period, use Accepted or Submitted, as appropriate.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/titleType/Other">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Other</skos:prefLabel>
    <skos:notation>Other</skos:notation>
    <skos:definition>Any title type not covered by the other values in the titleType controlled list.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/w3id">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>w3id</skos:prefLabel>
    <skos:altLabel>Permanent identifier for Web applications</skos:altLabel>
    <skos:notation>w3id</skos:notation>
    <skos:definition>Mostly used to publish vocabularies and ontologies. The letters ‘w3’ stand for “World Wide Web”.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="w3id" relationType="IsCitedBy">https://w3id.org/games/spec/coil#Coil_Bomb_Die_Of_Age</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/descriptionType/SeriesInformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>SeriesInformation</skos:prefLabel>
    <skos:notation>SeriesInformation</skos:notation>
    <skos:definition>Information about a repeating series, such as volume, issue, number.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/descriptionType"/>
    <skos:scopeNote>The information previously encoded as a description with this type should now be explicitly provided in tagged fields using the new RelatedItem property with relationType “IsPublishedIn” selected.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Submitted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Submitted</skos:prefLabel>
    <skos:notation>Submitted</skos:notation>
    <skos:definition>The date the creator submits the resource to the publisher. This could be different from Accepted if the publisher then applies a selection process.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:scopeNote>Recommended for discovery. To indicate the start of an embargo period, use Submitted or Accepted, as appropriate.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Sponsor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Sponsor</skos:prefLabel>
    <skos:notation>Sponsor</skos:notation>
    <skos:definition>Person or organisation that issued a contract or under the auspices of which a work has been written, printed, published, developed, etc.</skos:definition>
    <skos:scopeNote>Includes organisations that provide in-kind support (donation, people, facility, instrumentation) necessary for development of the resource.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType/CrossrefFunderID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Crossref Funder ID</skos:prefLabel>
    <skos:altLabel>Crossref Funder Registry ID</skos:altLabel>
    <skos:notation>Crossref Funder ID</skos:notation>
    <skos:definition>A persistent identifier for a funding body assigned by the Crossref Funder Registry, a curated, openly licensed registry of funder names and identifiers used to disambiguate funding organizations in scholarly metadata.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/funderIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Updated">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Updated</skos:prefLabel>
    <skos:notation>Updated</skos:notation>
    <skos:definition>The date of the last update to the resource, when the resource is being added to. May be a range.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Distributor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Distributor</skos:prefLabel>
    <skos:notation>Distributor</skos:notation>
    <skos:definition>Institution tasked with responsibility to generate/disseminate copies of the resource in either electronic or print form.</skos:definition>
    <skos:scopeNote>Works stored in more than one archive/repository may credit each as a distributor.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/URL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>URL</skos:prefLabel>
    <skos:altLabel>Uniform Resource Locator</skos:altLabel>
    <skos:notation>URL</skos:notation>
    <skos:definition>Also known as web address, a URL is a specific character string that constitutes a reference to a resource. The syntax is: scheme://domain:port/path?query_string#fragment_id.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URL" relationType="IsCitedBy">http://www.heatflow.und.edu/index2.html</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsNewVersionOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsNewVersionOf</skos:prefLabel>
    <skos:notation>IsNewVersionOf</skos:notation>
    <skos:definition>indicates A is a new edition of B, where the new edition has been modified or updated</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsNewVersionOf">10.5438/0005</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasTranslation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>HasTranslation</skos:prefLabel>
    <skos:notation>HasTranslation</skos:notation>
    <skos:definition>indicates A has a translation B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>When a resource is shared in one language and later translated, use HasTranslation to link original to translation. If released simultaneously in multiple languages, connect in both directions.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="HasTranslation">10.21384/g01j-jm06</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/dateType/Copyrighted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Copyrighted</skos:prefLabel>
    <skos:notation>Copyrighted</skos:notation>
    <skos:definition>The specific, documented date at which the resource receives a copyrighted status, if applicable.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/dateType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType/IGSN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IGSN</skos:prefLabel>
    <skos:altLabel>International Generic Sample Number</skos:altLabel>
    <skos:notation>IGSN</skos:notation>
    <skos:definition>A code that uniquely identifies samples from our natural environment and related features-of-interest.</skos:definition>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="IGSN" relationType="References">IECUR0097</relatedIdentifier>]]></skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relatedIdentifierType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/HasVersion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>HasVersion</skos:prefLabel>
    <skos:notation>HasVersion</skos:notation>
    <skos:definition>indicates A has a version B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>The registered resource such as a software package or code repository has a versioned instance (A has instance B). May relate an un-versioned code repository to a specific software version.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="HasVersion">10.5281/ZENODO.832053</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Translator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Translator</skos:prefLabel>
    <skos:notation>Translator</skos:notation>
    <skos:definition>A person, organization, or automated system responsible for converting the content of a resource from one language into another, preserving its meaning and intended message.</skos:definition>
    <skos:scopeNote>Apply to DOI metadata for a resource which has been translated from another resource.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsPreviousVersionOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsPreviousVersionOf</skos:prefLabel>
    <skos:notation>IsPreviousVersionOf</skos:notation>
    <skos:definition>indicates A is a previous edition of B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsPreviousVersionOf">10.5438/0007</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsRequiredBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsRequiredBy</skos:prefLabel>
    <skos:notation>IsRequiredBy</skos:notation>
    <skos:definition>Indicates A is required by B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May be used to indicate software dependencies.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsRequiredBy">10.1234/8675</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/numberType/Article">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Article</skos:prefLabel>
    <skos:notation>Article</skos:notation>
    <skos:definition>A number identifying an article within a journal issue or proceedings volume.</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/numberType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/titleType/TranslatedTitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>TranslatedTitle</skos:prefLabel>
    <skos:notation>TranslatedTitle</skos:notation>
    <skos:definition>A title that is a translation of the primary title into another language.</skos:definition>
    <skos:scopeNote>Use the xml:lang attribute to indicate the language of the translated title.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/titleType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/Editor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Editor</skos:prefLabel>
    <skos:notation>Editor</skos:notation>
    <skos:definition>A person who oversees the details related to the publication format of the resource.</skos:definition>
    <skos:scopeNote>If the Editor is to be credited in place of multiple creators, the Editor’s name may be supplied as Creator, with “(Ed.)” appended to the name.</skos:scopeNote>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsDescribedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsDescribedBy</skos:prefLabel>
    <skos:notation>IsDescribedBy</skos:notation>
    <skos:definition>indicates A is described by B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsDescribedBy">10.1038/sdata.2016.123</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/contributorType/DataCurator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>DataCurator</skos:prefLabel>
    <skos:notation>DataCurator</skos:notation>
    <skos:definition>Person tasked with reviewing, enhancing, cleaning, or standardizing metadata and the associated data submitted for storage, use, and maintenance within a data centre or repository.</skos:definition>
    <skos:scopeNote>While the DataManager is concerned with digital maintenance, the DataCurator’s role encompasses quality assurance focused on content and metadata. Responsibilities can include checking completeness; verifying standard metadata; adding/verifying specialized metadata; and determining how metadata maps to search engines, database products, and automated feeds. Repository managers and data librarians may fall within this category.</skos:scopeNote>
    <skos:example>https://doi.org/10.20375/0000-000D-1D1F-2</skos:example>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/contributorType"/>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsIdenticalTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsIdenticalTo</skos:prefLabel>
    <skos:notation>IsIdenticalTo</skos:notation>
    <skos:definition>indicates that A is identical to B, for use when there is a need to register two separate instances of the same resource</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>Use when the same resource is saved in another location (e.g., another institution).</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="URL" relationType="IsIdenticalTo">http://oac.cdlib.org/findaid/ark:/13030/c8r78fzq</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/IsVersionOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>IsVersionOf</skos:prefLabel>
    <skos:notation>IsVersionOf</skos:notation>
    <skos:definition>indicates A is a version of B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>The registered resource is an instance of a target resource (A is an instance of B). May relate a specific software version to its code repository.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="IsVersionOf">10.5281/ZENODO.832054</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
  <skos:Concept rdf:about="https://schema.stage.datacite.org/linked-data/vocab/relationType/Documents">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <skos:prefLabel>Documents</skos:prefLabel>
    <skos:notation>Documents</skos:notation>
    <skos:definition>indicates A is documentation about/explaining B</skos:definition>
    <skos:inScheme rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:topConceptOf rdf:resource="https://schema.stage.datacite.org/linked-data/vocab/relationType"/>
    <skos:scopeNote>May be used for software documentation.</skos:scopeNote>
    <skos:example><![CDATA[<relatedIdentifier relatedIdentifierType="DOI" relationType="Documents">10.1234/7836</relatedIdentifier>]]></skos:example>
  </skos:Concept>
  <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
</rdf:RDF>
